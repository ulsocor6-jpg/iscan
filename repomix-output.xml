// ── USDC BALANCE ────────────────────────────────────────────
async function getUSDCBalance(provider,address,chainId){
  var contract=USDC_CONTRACTS[chainId];
  if(!contract)return 0;
  try{
    var data='0x70a08231000000000000000000000000'+address.slice(2).padStart(64,'0');
    var result=await provider.request({method:'eth_call',params:[{to:contract,data},'latest']});
    return parseInt(result,16)/1e6;
  }catch(e){return 0;}
}

// ── CONNECT WALLET ──────────────────────────────────────────
async function connectWallet(type){
  // ── Ronin Wallet ──
  if(type==='ronin'){
    var roninProvider=window.ronin&&window.ronin.provider;
    if(!roninProvider){
      showMsg('walletMsg','error','Ronin Wallet not detected. Install from roninchain.com/wallet and refresh.');
      return;
    }
    try{
      showMsg('walletMsg','info','Connecting Ronin Wallet...');
      var accounts=await roninProvider.request({method:'eth_requestAccounts'});
      if(!accounts||!accounts.length){showMsg('walletMsg','error','No accounts returned.');return;}
      var address=accounts[0];
      var chainId='0x7e4'; // Ronin mainnet
      var chainInfo=CHAIN_MAP[chainId];
      var nativeBal=0;
      try{var bw=await roninProvider.request({method:'eth_getBalance',params:[address,'latest']});nativeBal=(parseInt(bw,16)/1e18).toFixed(4);}catch(e){}
      var r=await api('/api/v1/wallet/link',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address,provider:'ronin',chainId,nativeBalance:parseFloat(nativeBal),nativeToken:'RON',usdcBalance:0})});
      if(r.ok||r.data.success){
        showMsg('walletMsg','success','✅ Ronin connected: '+address.substring(0,6)+'...'+address.substring(address.length-4)+' | '+nativeBal+' RON');
        _syncIscanAddress(r.data);myAddress=address;loadWallets();loadWalletsForOverview();updateReceiveQR();
      }else showMsg('walletMsg','error',r.data.error||'Failed to link Ronin wallet.');
    }catch(err){
      if(err.code===4001)showMsg('walletMsg','error','Rejected. Please approve in Ronin Wallet.');
      else showMsg('walletMsg','error','Ronin error: '+err.message);
    }
    return;
  }

  // ── MetaMask ──
  if(!window.ethereum){
    showMsg('walletMsg','error','MetaMask not detected. Install from metamask.io and refresh.');
    return;
  }
  // Prefer MetaMask specifically if multiple providers injected
  var provider=null;
  if(window.ethereum.providers){provider=window.ethereum.providers.find(p=>p.isMetaMask&&!p.isRonin)||null;}
  if(!provider&&window.ethereum.isMetaMask&&!window.ethereum.isRonin)provider=window.ethereum;
  if(!provider){showMsg('walletMsg','error','MetaMask not found. Make sure it is installed and enabled.');return;}

  try{
    showMsg('walletMsg','info','Connecting MetaMask...');
    var accounts=await provider.request({method:'eth_requestAccounts'});
    if(!accounts||!accounts.length){showMsg('walletMsg','error','No accounts returned from MetaMask.');return;}
    var address=accounts[0];
    var chainId=await provider.request({method:'eth_chainId'});
    var chainInfo=CHAIN_MAP[chainId]||{name:'Unknown',token:'ETH',color:'#94a3b8'};
    var nativeBal=0;
    try{var bw=await provider.request({method:'eth_getBalance',params:[address,'latest']});nativeBal=(parseInt(bw,16)/1e18).toFixed(4);}catch(e){}
    var usdcBal=await getUSDCBalance(provider,address,chainId);
    var r=await api('/api/v1/wallet/link',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address,provider:'metamask',chainId,nativeBalance:parseFloat(nativeBal),nativeToken:chainInfo.token,usdcBalance:usdcBal})});
    if(r.ok||r.data.success){
      showMsg('walletMsg','success','✅ '+chainInfo.name+' connected: '+address.substring(0,6)+'...'+address.substring(address.length-4)+' | '+nativeBal+' '+chainInfo.token+(usdcBal>0?' | '+usdcBal.toFixed(2)+' USDC':''));
      _syncIscanAddress(r.data);myAddress=address;loadWallets();loadWalletsForOverview();updateReceiveQR();
    }else showMsg('walletMsg','error',r.data.error||'Failed to link wallet.');
  }catch(err){
    if(err.code===4001)showMsg('walletMsg','error','Rejected. Please approve in MetaMask.');
    else showMsg('walletMsg','error','MetaMask error: '+err.message);
  }
}

function _syncIscanAddress(data){
  if(!data||!data.iscanAddress)return;
  myIscanAddress=data.iscanAddress;
  ['iscanAddrWallet','iscanAddrDisplay','myIscanAddr','receiveIscanAddr'].forEach(function(id){var el=document.getElementById(id);if(el)el.textContent=myIscanAddress;});
  renderIscanQR(myIscanAddress);
}

// ── UNLINK WALLET ───────────────────────────────────────────
async function unlinkWallet(address){
  if(!confirm('Unlink wallet '+address.substring(0,10)+'...?\nThis removes it from ISCAN only — your actual wallet is unaffected.'))return;
  var r=await api('/api/v1/wallet/unlink',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address})});
  if(r.ok&&r.data.success){
    showMsg('walletMsg','success','Wallet unlinked successfully.');
    loadWallets();loadWalletsForOverview();updateReceiveQR();
  }else showMsg('walletMsg','error',r.data.error||'Unlink failed.');
}

// ── LOAD WALLETS (renders list with unlink buttons) ─────────
async function loadWallets(){
  var r=await api('/api/v1/wallet/list');
  var el=document.getElementById('walletList');
  if(!el)return;
  var wallets=r.data&&r.data.wallets;
  var iscanAddr=r.data&&r.data.iscanAddress;
  if(iscanAddr)_syncIscanAddress(r.data);
  if(!wallets||wallets.length===0){
    el.innerHTML='<p style="color:#6b7280;font-size:12px;">No wallets linked yet. Connect one above.</p>';
    return;
  }
  el.innerHTML=wallets.map(function(w){
    var chainInfo=CHAIN_MAP[w.chainId]||{name:'Unknown',token:w.nativeToken||'?',color:'#94a3b8'};
    var shortAddr=w.address.substring(0,10)+'...'+w.address.substring(w.address.length-6);
    var providerLabel=(w.provider||'wallet').toUpperCase();
    var providerBadgeColor=w.provider==='ronin'?'#cfe2ff':'#fff3cd';
    var providerTextColor=w.provider==='ronin'?'#084298':'#856404';
    return '<div class="wallet-item">'+
      '<div class="wallet-header">'+
        '<div>'+
          '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">'+
            '<span class="network-badge" style="color:'+chainInfo.color+';border:1px solid '+chainInfo.color+'40;background:'+chainInfo.color+'15;">'+chainInfo.name+'</span>'+
            '<span class="badge" style="background:'+providerBadgeColor+';color:'+providerTextColor+';">'+providerLabel+'</span>'+
          '</div>'+
          '<span class="wallet-addr">'+shortAddr+'</span>'+
        '</div>'+
        '<button class="btn-unlink" onclick="unlinkWallet(\''+w.address+'\')">🔌 Unlink</button>'+
      '</div>'+
      '<div class="wallet-tokens" style="margin-top:8px;">'+
        '<span class="token-chip" style="color:'+chainInfo.color+'">'+(w.nativeBalance||0)+' '+chainInfo.token+'</span>'+
        (w.usdcBalance>0?'<span class="token-chip" style="color:#2775ca">'+(parseFloat(w.usdcBalance)||0).toFixed(2)+' USDC</span>':'')+
      '</div>'+
    '</div>';
  }).join('');
  // Set default active address for QR
  if(wallets[0])myAddress=wallets[0].address;
}

// ── RECEIVE TAB: chain/token selector logic ─────────────────
var _receiveChain='0x1', _receiveToken='native', _linkedWallets=[];

function selectReceiveChain(btn){
  document.querySelectorAll('#chainSelector .chain-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  _receiveChain=btn.dataset.chain;
  updateReceiveQR();
}
function selectReceiveToken(btn){
  document.querySelectorAll('#tokenSelector .chain-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  _receiveToken=btn.dataset.token;
  updateReceiveQR();
}
async function updateReceiveQR(){
  var r=await api('/api/v1/wallet/list');
  _linkedWallets=r.data&&r.data.wallets||[];
  // Find wallet matching selected chain
  var matched=_linkedWallets.find(w=>w.chainId===_receiveChain);
  var out=document.getElementById('cryptoReceiveOutput');
  var noWallet=document.getElementById('cryptoReceiveNoWallet');
  if(!matched){
    if(out)out.style.display='none';
    if(noWallet)noWallet.style.display='block';
    return;
  }
  if(noWallet)noWallet.style.display='none';
  if(out)out.style.display='block';
  var chainInfo=CHAIN_MAP[_receiveChain]||{token:'ETH'};
  var tokenLabel=_receiveToken==='native'?chainInfo.token:_receiveToken;
  var qrText=matched.address; // optionally: 'ethereum:'+address+'?token=USDC'
  renderQR(qrText);
  myAddress=matched.address;
}

// ── QR ──────────────────────────────────────────────────────
var myAddress='',qrInstance=null;
async function loadMyWalletForQR(){
  var r=await api('/api/v1/wallet/list');
  var wallets=r.data&&r.data.wallets;
  _linkedWallets=wallets||[];
  if(wallets&&wallets.length>0){myAddress=wallets[0].address;updateReceiveQR();}
}
function renderQR(text){
  var el=document.getElementById('qrCanvas');
  if(!el||!text)return;
  try{el.getContext('2d').clearRect(0,0,180,180);}catch(e){}
  try{
    if(qrInstance){qrInstance.clear();qrInstance.makeCode(text);}
    else qrInstance=new QRCode(el,{text,width:180,height:180,colorDark:'#000',colorLight:'#fff'});
  }catch(e){}
  var addrEl=document.getElementById('myWalletAddr');
  if(addrEl)addrEl.textContent=text;
}
function generateRequestQR(){
  var amount=document.getElementById('requestAmount').value;
  var currency=document.getElementById('requestCurrency').value;
  var note=document.getElementById('requestNote').value;
  if(!myAddress){showMsg('requestMsg','error','Connect a wallet and select a chain first.');return;}
  if(!amount){showMsg('requestMsg','error','Enter an amount.');return;}
  var out=document.getElementById('cryptoReceiveOutput');if(out)out.style.display='block';
  renderQR(JSON.stringify({address:myAddress,amount:parseFloat(amount),currency,note}));
  showMsg('requestMsg','success','QR generated for '+amount+' '+currency);
}
function copyMyAddress(){
  if(!myAddress){alert('No crypto wallet address available for this chain.');return;}
  navigator.clipboard.writeText(myAddress).then(()=>alert('Address copied!')).catch(()=>{});
}

// ── SWAP ─────────────────────────────────────────────────────
function updateSwapPreview(){
  var amount=parseFloat(document.getElementById('swapAmount').value);
  var from=document.getElementById('swapFrom').value;
  var to=document.getElementById('swapTo').value;
  var box=document.getElementById('swapPreviewBox');
  if(!amount||amount<=0){box.style.display='none';return;}
  if(from===to){box.style.display='none';showMsg('swapMsg','error','Select different tokens.');return;}
  box.style.display='block';
  var fee=parseFloat((amount*0.003).toFixed(6));
  var net=amount-fee;
  // If converting to/from PHP use live rate
  var rateStr='1:1 (internal)';
  if(from!=='PHP'&&to==='PHP'&&liveRates[from]){
    var php=(net*liveRates[from]);
    document.getElementById('swapPreviewFrom').textContent=amount+' '+from;
    document.getElementById('swapPreviewRate').textContent='₱'+Number(liveRates[from]).toLocaleString();
    document.getElementById('swapPreviewFee').textContent=fee+' '+from;
    document.getElementById('swapPreviewTotal').textContent='₱'+php.toFixed(2);
    return;
  }
  document.getElementById('swapPreviewFrom').textContent=amount+' '+from;
  document.getElementById('swapPreviewRate').textContent=rateStr;
  document.getElementById('swapPreviewFee').textContent=fee+' '+from;
  document.getElementById('swapPreviewTotal').textContent=net.toFixed(6)+' '+to;
}

async function executeSwap(){
  var amount=parseFloat(document.getElementById('swapAmount').value);
  var from=document.getElementById('swapFrom').value;
  var to=document.getElementById('swapTo').value;
  if(!amount||amount<=0){showMsg('swapMsg','error','Enter a valid amount.');return;}
  if(from===to){showMsg('swapMsg','error','Select different tokens.');return;}
  showMsg('swapMsg','info','Processing swap...');
  var r=await api('/api/v1/swap/execute',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({fromToken:from,toToken:to,amount})
  });
  if(r.ok&&(r.data.success||r.data.referenceId)){
    showMsg('swapMsg','success','✅ Swap complete! Ref: '+(r.data.referenceId||'—'));
    document.getElementById('swapAmount').value='';
    document.getElementById('swapPreviewBox').style.display='none';
    loadBalance();
  }else{
    showMsg('swapMsg','error',r.data.error||r.data.message||'Swap failed.');
  }
}

// ── SEND PREVIEW ─────────────────────────────────────────────
function updatePreview(){
  var amount=parseFloat(document.getElementById('sendAmount').value);
  var currency=document.getElementById('sendCurrency').value;
  var box=document.getElementById('previewBox');
  if(!amount||amount<=0){box.style.display='none';return;}
  box.style.display='block';
  if(currency==='PHP'){
    document.getElementById('previewAmount').textContent='₱'+amount.toLocaleString();
    document.getElementById('previewRate').textContent='Internal PHP';
    document.getElementById('previewFee').textContent='₱'+(amount*0.005).toFixed(2);
    document.getElementById('previewTotal').textContent='₱'+(amount*0.995).toFixed(2);
    return;
  }
  var rate=liveRates[currency];
  if(!rate){box.style.display='none';showMsg('sendMsg','info','Rate for '+currency+' not available yet.');return;}
  var fee=parseFloat((amount*0.005).toFixed(6));
  var php=parseFloat(((amount-fee)*rate).toFixed(2));
  document.getElementById('previewAmount').textContent=amount+' '+currency;
  document.getElementById('previewRate').textContent='₱'+Number(rate).toLocaleString();
  document.getElementById('previewFee').textContent=fee+' '+currency;
  document.getElementById('previewTotal').textContent='₱'+Number(php).toLocaleString();
}

// ── SEND PAYMENT ──────────────────────────────────────────────
async function sendPayment(){
  var amount=parseFloat(document.getElementById('sendAmount').value);
  var currency=document.getElementById('sendCurrency').value;
  var notes=document.getElementById('sendNotes').value.trim();
  if(!amount||amount<=0){showMsg('sendMsg','error','Enter a valid amount.');return;}
  var activeMode='crypto';
  ['crypto','email','bill'].forEach(m=>{if(document.getElementById('mode-'+m).style.display!=='none')activeMode=m;});
  if(activeMode==='email'){
    var email=document.getElementById('receiverEmail').value.trim();
    if(!email){showMsg('sendMsg','error','Enter recipient email.');return;}
    var r2=await api('/api/v1/transfer/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({receiverEmail:email,amount})});
    if(r2.ok){showMsg('sendMsg','success','Sent! Ref: '+r2.data.referenceId);loadBalance();}
    else showMsg('sendMsg','error',r2.data.error||'Transfer failed.');
    return;
  }
  var body={amount,currency,notes};
  if(activeMode==='crypto'){
    body.senderAddress=document.getElementById('senderAddr').value.trim();
    body.receiverAddress=document.getElementById('receiverAddr').value.trim();
    if(!body.senderAddress||!body.receiverAddress){showMsg('sendMsg','error','Fill in both wallet addresses.');return;}
  }else{
    var biller=document.getElementById('billerType').value;
    var accNo=document.getElementById('billAccountNo').value.trim();
    if(!biller||!accNo){showMsg('sendMsg','error','Select biller and enter account number.');return;}
    body.senderAddress='ISCAN-BILLS';
    body.receiverAddress='BILLS-'+biller.toUpperCase();
    body.notes='Bill payment: '+biller+' — '+accNo;
  }
  var r=await api('/api/v1/remittance/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  if(r.ok){
    var tx=r.data.transaction;
    showMsg('sendMsg','success','Sent! Ref: '+tx.referenceId+(tx.phpEquivalent?' | Recipient gets ₱'+Number(tx.phpEquivalent).toLocaleString():''));
    document.getElementById('previewBox').style.display='none';
    document.getElementById('sendAmount').value='';
  }else showMsg('sendMsg','error',r.data.message||'Send failed.');
}

// ── ISCAN TRANSFER ────────────────────────────────────────────
async function iscanTransfer(){
  var receiverEmail=document.getElementById('iscanReceiverEmail').value.trim();
  var amount=parseFloat(document.getElementById('iscanAmount').value);
  if(!receiverEmail||!amount||amount<=0){showMsg('iscanMsg','error','Enter recipient and amount.');return;}
  var r=await api('/api/v1/transfer/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({receiverEmail,amount})});
  if(r.ok){
    showMsg('iscanMsg','success','Transfer complete! Ref: '+r.data.referenceId);
    document.getElementById('iscanAmount').value='';
    loadBalance();
  }else showMsg('iscanMsg','error',r.data.error||'Transfer failed.');
}

// ── CASH IN ───────────────────────────────────────────────────
async function quickCashIn(){
  var amount=parseFloat(document.getElementById('quickCashinAmount').value);
  var msg=document.getElementById('quickCashinMsg');
  if(!amount||amount<20){msg.className='msg error';msg.textContent='Minimum ₱20';return;}
  msg.className='msg info';msg.textContent='Creating payment link...';
  try{
    var res=await fetch('/api/v1/payment/cashin',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({amount})});
    var data=await res.json();
    if(!res.ok)throw new Error(data.error||'Failed');
    msg.className='msg success';
    msg.innerHTML='✅ Link ready! <a href="'+data.checkoutUrl+'" target="_blank" style="color:#34d399;font-weight:bold;text-decoration:underline;">Pay via GCash / Card ↗</a>';
  }catch(err){msg.className='msg error';msg.textContent='Error: '+err.message;}
}
async function startCashIn(){
  var amount=parseFloat(document.getElementById('cashinAmount').value);
  var msg=document.getElementById('cashinMsg');
  if(!amount||amount<20){msg.className='msg error';msg.textContent='Minimum ₱20';return;}
  msg.className='msg info';msg.textContent='Creating payment link...';
  try{
    var res=await fetch('/api/v1/payment/cashin',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({amount})});
    var data=await res.json();
    if(!res.ok)throw new Error(data.error||'Failed');
    msg.className='msg success';
    msg.innerHTML='✅ Payment link ready! <a href="'+data.checkoutUrl+'" target="_blank" style="color:#34d399;text-decoration:underline;font-weight:bold;">Click here to pay via GCash / Card ↗</a>';
  }catch(err){msg.className='msg error';msg.textContent='Error: '+err.message;}
}

// ── SCANNER ───────────────────────────────────────────────────
var scanStream=null,scanInterval=null;
async function startScan(){
  try{
    scanStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});
    var v=document.getElementById('scanVideo');v.srcObject=scanStream;v.style.display='block';
    showMsg('scanMsg','info','Camera active. Point at a QR code.');
    scanInterval=setInterval(scanFrame,500);
  }catch(e){showMsg('scanMsg','error','Camera denied: '+e.message);}
}
function stopScan(){
  if(scanStream)scanStream.getTracks().forEach(t=>t.stop());
  document.getElementById('scanVideo').style.display='none';
  clearInterval(scanInterval);
}
function scanFrame(){
  var v=document.getElementById('scanVideo'),c=document.getElementById('scanCanvas');
  if(v.readyState!==v.HAVE_ENOUGH_DATA)return;
  c.width=v.videoWidth;c.height=v.videoHeight;
  c.getContext('2d').drawImage(v,0,0);
  if('BarcodeDetector' in window){
    new BarcodeDetector({formats:['qr_code']}).detect(c).then(codes=>{
      if(codes.length){handleScanResult(codes[0].rawValue);stopScan();}
    }).catch(()=>{});
  }
}
function handleScanResult(raw){
  var el=document.getElementById('scanResult');el.style.display='block';
  try{
    var d=JSON.parse(raw);
    el.textContent='Address: '+d.address+(d.amount?'\nAmount: '+d.amount+' '+d.currency:'')+(d.note?'\nNote: '+d.note:'');
    document.getElementById('receiverAddr').value=d.address;
    if(d.amount)document.getElementById('sendAmount').value=d.amount;
    if(d.currency)document.getElementById('sendCurrency').value=d.currency;
    showMsg('scanMsg','success','Scanned! Send form auto-filled. Go to Send tab.');
  }catch(e){
    el.textContent=raw;
    document.getElementById('receiverAddr').value=raw;
    showMsg('scanMsg','success','Address filled in send form.');
  }
}

// ── LEDGER ────────────────────────────────────────────────────
async function loadLedger(){
  var r=await api('/api/v1/ledger/history'),el=document.getElementById('ledgerContent');
  if(!r.ok||!r.data.entries||r.data.entries.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No ledger entries yet.</p>';return;}
  document.getElementById('ledgerBalance').textContent='₱'+Number(r.data.balance||0).toLocaleString('en',{minimumFractionDigits:2});
  el.innerHTML='<table class="ledger-table"><thead><tr><th>Type</th><th>Debit</th><th>Credit</th><th>Reference ID</th><th>Description</th><th>Timestamp</th><th>Status</th></tr></thead><tbody>'+
    r.data.entries.map(e=>'<tr>'+
      '<td style="color:#94a3b8;">'+e.transactionType+'</td>'+
      '<td class="debit">'+(e.debit>0?'₱'+Number(e.debit).toLocaleString('en',{minimumFractionDigits:2}):'—')+'</td>'+
      '<td class="credit">'+(e.credit>0?'₱'+Number(e.credit).toLocaleString('en',{minimumFractionDigits:2}):'—')+'</td>'+
      '<td class="ref">'+e.referenceId+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+e.description+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+new Date(e.createdAt).toLocaleString()+'</td>'+
      '<td><span class="badge '+e.status+'">'+e.status.toUpperCase()+'</span></td>'+
    '</tr>').join('')+'</tbody></table>';
}

async function loadOnrampHistory(){
  var el=document.getElementById('ledgerContent');
  el.innerHTML='<p style="color:#6b7280;font-size:12px;">Loading crypto onramp history…</p>';
  var r=await api('/api/v1/onramp/history');
  if(!r.ok||!r.data.entries||r.data.entries.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No crypto onramp transactions yet.</p>';return;}
  el.innerHTML='<div style="margin-bottom:8px;font-size:11px;color:#2de8a2;font-weight:600;">🪙 Showing crypto onramp entries only</div>'+
    '<table class="ledger-table"><thead><tr><th>Token</th><th>USD</th><th>PHP Rate</th><th>Fee</th><th>Net PHP</th><th>Channel</th><th>Reference</th><th>Date</th><th>Status</th></tr></thead><tbody>'+
    r.data.entries.map(function(e){
      var desc=e.description||'';
      var tokenMatch=desc.match(/^(USDC|USDT)/);var token=tokenMatch?tokenMatch[1]:'—';
      var rateMatch=desc.match(/Rate: ₱([\d.]+)/);var rate=rateMatch?'₱'+rateMatch[1]:'—';
      var chanMatch=desc.match(/via (\w+)/);var chan=chanMatch?chanMatch[1]:'—';
      return '<tr>'+
        '<td><span class="badge" style="background:'+(token==='USDC'?'#1a3a5c':'#1a3d2e')+';color:'+(token==='USDC'?'#60a5fa':'#34d399')+'">'+token+'</span></td>'+
        '<td style="color:#f9fafb;font-weight:600;">'+(e.amount&&rate!=='—'?'$'+(e.amount/(parseFloat(rate.replace('₱',''))||1)).toFixed(2):'—')+'</td>'+
        '<td style="color:#94a3b8;font-size:11px;">'+rate+'</td>'+
        '<td style="color:#f87171;font-size:11px;">'+(e.feePHP?'₱'+Number(e.feePHP).toLocaleString('en',{minimumFractionDigits:2}):'—')+'</td>'+
        '<td class="credit">₱'+Number(e.amount||0).toLocaleString('en',{minimumFractionDigits:2})+'</td>'+
        '<td style="color:#94a3b8;font-size:11px;text-transform:capitalize;">'+chan+'</td>'+
        '<td class="ref">'+e.referenceId+'</td>'+
        '<td style="color:#6b7280;font-size:11px;">'+new Date(e.createdAt).toLocaleString()+'</td>'+
        '<td><span class="badge '+e.status+'">'+e.status.toUpperCase()+'</span></td>'+
      '</tr>';
    }).join('')+'</tbody></table>';
}

async function loadRecentLedger(){
  var r=await api('/api/v1/ledger/history'),el=document.getElementById('recentLedger');
  if(!r.ok||!r.data.entries||r.data.entries.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No activity yet.</p>';return;}
  el.innerHTML=r.data.entries.slice(0,5).map(e=>{
    var c=e.credit>0;
    return '<div class="activity-row">'+
      '<div><span style="color:#94a3b8;">'+e.transactionType+'</span> <span class="ref"> '+e.referenceId+'</span></div>'+
      '<span class="'+(c?'credit':'debit')+'">'+(c?'+':'−')+'₱'+Number(c?e.credit:e.debit).toLocaleString()+'</span>'+
    '</div>';
  }).join('');
}

// ── SETTLEMENT ────────────────────────────────────────────────
async function loadPending(){
  var r=await api('/api/v1/remittance/pending'),el=document.getElementById('pendingList');
  if(!r.ok||!r.data.transactions||r.data.transactions.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No pending settlements.</p>';return;}
  el.innerHTML='<table class="ledger-table"><thead><tr><th>Reference</th><th>Amount</th><th>PHP Value</th><th>Date</th><th>Action</th></tr></thead><tbody>'+
    r.data.transactions.map(tx=>'<tr>'+
      '<td class="ref">'+tx.referenceId+'</td>'+
      '<td>'+tx.amount+' '+tx.currency+'</td>'+
      '<td class="credit">₱'+Number(tx.phpEquivalent||0).toLocaleString()+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+new Date(tx.createdAt).toLocaleDateString()+'</td>'+
      '<td><button class="btn btn-green btn-sm" onclick="settleNow(\''+tx._id+'\')">Settle</button></td>'+
    '</tr>').join('')+'</tbody></table>';
}
async function settleNow(id){
  var phone=prompt('Recipient Coins.ph phone (e.g. 09171234567):');
  if(!phone)return;
  var r=await api('/api/v1/remittance/settle/'+id,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({recipientPhone:phone})});
  alert(r.ok?(r.data.result&&r.data.result.mock?'Queued (Coins.ph API pending)':'Settled!'):'Failed: '+(r.data&&r.data.message));
  if(r.ok)loadPending();
}

// ── AUDIT ─────────────────────────────────────────────────────
async function loadAudit(){
  var r=await api('/api/v1/remittance/audit'),el=document.getElementById('auditList');
  if(!r.ok||!r.data.logs||r.data.logs.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No records yet.</p>';return;}
  el.innerHTML='<table class="ledger-table"><thead><tr><th>Action</th><th>Entity</th><th>Reference</th><th>Timestamp</th><th>Status</th></tr></thead><tbody>'+
    r.data.logs.map(l=>'<tr>'+
      '<td style="color:#c084fc;font-weight:600;">'+l.action+'</td>'+
      '<td style="color:#94a3b8;">'+l.entity+'</td>'+
      '<td class="ref">'+(l.details&&l.details.referenceId?l.details.referenceId:'—')+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+new Date(l.createdAt).toLocaleString()+'</td>'+
      '<td><span class="badge '+(l.status||'success')+'">'+l.status.toUpperCase()+'</span></td>'+
    '</tr>').join('')+'</tbody></table>';
}

// ── ACCOUNTS ──────────────────────────────────────────────────
function loadProfile(){
  document.getElementById('profileInfo').innerHTML=
    '<div><strong>Email:</strong> '+userEmail+'</div>'+
    '<div><strong>Name:</strong> '+(userName||'—')+'</div>';
  document.getElementById('kycStatus').innerHTML=
    '<span class="badge pending">UNVERIFIED</span>'+
    '<p style="margin-top:6px;color:#6b7280;font-size:11px;">Upload a government ID to verify and unlock higher limits.</p>';
}
async function uploadKYC(e){
  var file=e.target.files[0];if(!file)return;
  var fd=new FormData();fd.append('image',file);
  var res=await fetch('/api/v1/kyc/upload-id',{method:'POST',credentials:'same-origin',body:fd});
  var d=await res.json();
  showMsg('kycMsg',d.success?'success':'error',d.success?'ID uploaded.':d.error||'Failed.');
}
async function addBank(){
  var bN=document.getElementById('bankName').value.trim();
  var aN=document.getElementById('accountName').value.trim();
  var aNo=document.getElementById('accountNumber').value.trim();
  if(!bN||!aN||!aNo){showMsg('bankMsg','error','Fill all fields.');return;}
  var r=await api('/api/v1/bank/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({bankName:bN,accountName:aN,accountNumber:aNo})});
  if(r.ok){showMsg('bankMsg','success','Bank added.');document.getElementById('bankName').value='';document.getElementById('accountName').value='';document.getElementById('accountNumber').value='';loadBanks();}
  else showMsg('bankMsg','error',r.data.error||'Failed.');
}
async function loadBanks(){
  var r=await api('/api/v1/bank/list'),el=document.getElementById('bankList');
  if(!r.ok||!r.data.banks||r.data.banks.length===0){el.innerHTML='<p style="color:#6b7280;font-size:11px;margin-top:6px;">No banks linked.</p>';return;}
  el.innerHTML=r.data.banks.map(b=>'<div class="wallet-item"><div><strong>'+b.bankName+'</strong><br><span style="color:#6b7280;font-size:11px;">'+b.accountName+' — '+b.accountNumber+'</span></div></div>').join('');
}

// ── INIT ──────────────────────────────────────────────────────
loadRates();
setInterval(loadRates,60000);
loadBalance();
loadRecentLedger();
loadWalletsForOverview();
// Pre-load ISCAN address so it's ready everywhere
loadIscanAddressAll();
</script>
</body>
</html>
