.credit{color:#34d399;font-weight:600;}
.ref{font-family:monospace;color:#60a5fa;font-size:10px;}
.badge{display:inline-block;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700;}
.badge.completed,.badge.success{background:#064e3b;color:#34d399;}
.badge.pending{background:#78350f;color:#fcd34d;}
.badge.failed{background:#450a0a;color:#f87171;}
.badge.reversed{background:#1e1b4b;color:#a5b4fc;}
.badge.metamask{background:#fff3cd;color:#856404;}
.badge.ronin{background:#cfe2ff;color:#084298;}
#qrCanvas{display:block;margin:12px auto 0;border-radius:10px;background:white;padding:6px;}
#scanVideo{width:100%;border-radius:10px;display:none;margin-top:10px;}
#scanResult{margin-top:8px;padding:9px;background:#0b1220;border:1px solid #1f2937;border-radius:8px;font-family:monospace;font-size:11px;color:#60a5fa;display:none;word-break:break-all;}
.wallet-item{background:#0b1220;border:1px solid #1f2937;border-radius:10px;margin-top:8px;padding:12px;font-size:12px;}
