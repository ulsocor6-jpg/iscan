            startPolling();
          } catch (err) {
            document.getElementById('or-deposit-addr').textContent = '⚠ Could not generate address. Try refreshing.';
            console.error('[ONRAMP] generateDepositAddress:', err);
          }
        }

        // ── Copy address ──────────────────────────────────────────────────
        window.copyDepositAddr = function () {
          if (!_depositAddr) return;
          navigator.clipboard.writeText(_depositAddr).then(() => {
            const btn = document.querySelector('.deposit-actions button');
            const orig = btn.textContent;
            btn.textContent = '✅ Copied!';
            setTimeout(() => btn.textContent = orig, 1800);
          });
        };

        window.showDepositQR = function () {
          alert('QR for: ' + _depositAddr); // replace with your QR modal if available
        };

        // ── Poll backend for deposit detection ────────────────────────────
        function startPolling() {
          if (_pollTimer) clearInterval(_pollTimer);
          _pollTimer = setInterval(pollDepositStatus, 8000); // every 8s
          pollDepositStatus(); // immediate first check
        }

        async function pollDepositStatus() {
          if (!_depositId) return;
          try {
            const res  = await fetch(`/api/v1/onramp/deposit-status/${_depositId}`, { credentials: 'include' });
            const data = await res.json();

            const statusEl  = document.getElementById('or-detect-status');
            const msgEl     = document.getElementById('or-detect-msg');
            const submitBtn = document.getElementById('or-submit-btn');

            if (data.status === 'deposit_detected' || data.status === 'confirming') {
              statusEl.className = 'detect-status confirming';
              statusEl.innerHTML = '<div class="detect-spinner"></div><span id="or-detect-msg">Transfer detected — confirming on-chain (' + (data.confirmations || 1) + '/3 confirmations)…</span>';
            }

            if (data.status === 'processing' || data.status === 'completed') {
              clearInterval(_pollTimer);
              _detected = true;
              statusEl.className = 'detect-status detected';
              statusEl.innerHTML = '✅ <span>Transfer confirmed! Click the button below to complete your payout.</span>';
              submitBtn.disabled = false;

              // If backend already completed the payout automatically
              if (data.status === 'completed' && data.referenceId) {
                showOrStatus('success',
                  `✅ Done! ₱${data.netPHP ? data.netPHP.toFixed(2) : '—'} sent via ${_channel.toUpperCase()}.\nReference: ${data.referenceId}`
                );
                submitBtn.style.display = 'none';
                if (typeof loadBalance === 'function') loadBalance();
                if (typeof loadRecentLedger === 'function') loadRecentLedger();
              }
            }

            if (data.status === 'failed') {
              clearInterval(_pollTimer);
              statusEl.className = 'detect-status waiting';
              statusEl.innerHTML = '⚠ Deposit check failed. Contact support with your reference.';
            }

          } catch (err) {
            console.warn('[ONRAMP] poll error:', err.message);
          }
        }

        // ── Submit conversion (called after detection confirmed) ──────────
        window.submitConversion = async function () {
          if (!_detected && !_depositId) return showOrStatus('error', 'Wait for your deposit to be detected first.');

          const usdAmount    = parseFloat(document.getElementById('or-usd-amount').value);
          const mobileRaw    = document.getElementById('or-mobile').value.trim();
          const mobileNumber = '+63' + mobileRaw;

          if (!usdAmount || usdAmount < 1) return showOrStatus('error', 'Enter a valid USD amount (min $1).');
          if (!/^9\d{9}$/.test(mobileRaw))  return showOrStatus('error', 'Enter a valid PH mobile number (9XXXXXXXXX).');

          const btn = document.getElementById('or-submit-btn');
          btn.disabled = true;
          btn.textContent = 'Processing…';
          showOrStatus('pending', `⏳ Converting $${usdAmount} ${_token} → PHP via ${_channel.toUpperCase()}…`);
          document.getElementById('or-gcash-notice').style.display = 'none';

          try {
            const res  = await fetch('/api/v1/onramp/convert', {
              method: 'POST',
              credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                token: _token,
                usdAmount,
                channel: _channel,
                mobileNumber,
                depositId: _depositId,   // backend uses this instead of txHash
              }),
            });
            const data = await res.json();
            if (!res.ok || !data.success) throw new Error(data.error || 'Conversion failed');

            showOrStatus('success',
              `✅ Success! ₱${data.netPHP.toFixed(2)} sent to ${mobileNumber} via ${_channel.toUpperCase()}.\nReference: ${data.referenceId}`
            );

            if (_channel === 'gcash' && data.redirectUrl) {
              const link = document.getElementById('or-gcash-link');
              link.href = data.redirectUrl;
              document.getElementById('or-gcash-notice').style.display = 'block';
              window.open(data.redirectUrl, '_blank');
            }

            if (typeof loadBalance === 'function') loadBalance();
            if (typeof loadRecentLedger === 'function') loadRecentLedger();

            setTimeout(resetOrForm, 4000);
          } catch (err) {
            showOrStatus('error', `❌ ${err.message}`);
            btn.disabled = false;
            btn.innerHTML = `Convert &amp; Send to <span id="or-channel-label">${_channel === 'maya' ? 'Maya' : 'GCash'}</span>`;
          }
        };

        // ── Helpers ───────────────────────────────────────────────────────
        function showOrStatus(type, msg) {
          const el = document.getElementById('or-status');
          el.className = `status-banner ${type}`;
          el.textContent = msg;
          el.style.display = 'block';
        }

        function resetDeposit() {
          if (_pollTimer) clearInterval(_pollTimer);
          _depositAddr = null;
          _depositId   = null;
          _detected    = false;
          document.getElementById('or-deposit-addr').textContent = 'Enter amount and mobile number above to generate your deposit address.';
          document.getElementById('or-deposit-actions').style.display = 'none';
          document.getElementById('or-network-chips').style.display   = 'none';
          document.getElementById('or-detect-status').style.display   = 'none';
          document.getElementById('or-submit-btn').disabled = true;
        }

        function resetOrForm() {
          document.getElementById('or-usd-amount').value = '';
          document.getElementById('or-mobile').value     = '';
          document.getElementById('or-breakdown').style.display = 'none';
          document.getElementById('or-status').style.display    = 'none';
          resetDeposit();
        }

        // Auto-fetch rate on load; also poll every 60s
        refreshRate();
        setInterval(refreshRate, 60_000);
      })();
      </script>
    </div><!-- /card -->
  </div><!-- /crypto-cashin-tab -->
