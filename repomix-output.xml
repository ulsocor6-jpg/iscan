      unique: true
    },

    iscanAddress: {
      type: String,
      required: true,
      unique: true
    },

    balances: {
      type: Map,
      of: Number,
      default: {}
    },

    linkedWallets: {
      type: [linkedWalletSchema],
      default: []
    },

    status: {
      type: String,
      enum: ['active', 'suspended'],
      default: 'active'
    }
  },
  {
    timestamps: true
  }
);

export default mongoose.model('Wallet', walletSchema);
