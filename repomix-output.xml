function renderQR(text){
  var el=document.getElementById('qrCanvas');
  if(!el)return;
  el.getContext('2d').clearRect(0,0,180,180);
  try{
    if(qrInstance){qrInstance.clear();qrInstance.makeCode(text);}
    else qrInstance=new QRCode(el,{text,width:180,height:180,colorDark:'#000',colorLight:'#fff'});
  }catch(e){}
  document.getElementById('myWalletAddr').textContent=text;
}
function generateRequestQR(){
  var amount=document.getElementById('requestAmount').value;
  var currency=document.getElementById('requestCurrency').value;
  var note=document.getElementById('requestNote').value;
  if(!myAddress){showMsg('requestMsg','error','Connect a wallet first.');return;}
  if(!amount){showMsg('requestMsg','error','Enter an amount.');return;}
  renderQR(JSON.stringify({address:myAddress,amount:parseFloat(amount),currency,note}));
  showMsg('requestMsg','success','QR generated for '+amount+' '+currency);
}
function copyMyAddress(){
  if(!myAddress){alert('No crypto wallet connected.');return;}
  navigator.clipboard.writeText(myAddress).then(()=>alert('Crypto address copied!'));
}

// ── SWAP ─────────────────────────────────────────────────────
function updateSwapPreview(){
  var amount=parseFloat(document.getElementById('swapAmount').value);
  var from=document.getElementById('swapFrom').value;
  var to=document.getElementById('swapTo').value;
  var box=document.getElementById('swapPreviewBox');
  if(!amount||amount<=0){box.style.display='none';return;}
  if(from===to){box.style.display='none';showMsg('swapMsg','error','Select different tokens.');return;}
  box.style.display='block';
  var fee=parseFloat((amount*0.003).toFixed(6));
  var net=amount-fee;
  // If converting to/from PHP use live rate
  var rateStr='1:1 (internal)';
  if(from!=='PHP'&&to==='PHP'&&liveRates[from]){
    var php=(net*liveRates[from]);
    document.getElementById('swapPreviewFrom').textContent=amount+' '+from;
    document.getElementById('swapPreviewRate').textContent='₱'+Number(liveRates[from]).toLocaleString();
    document.getElementById('swapPreviewFee').textContent=fee+' '+from;
    document.getElementById('swapPreviewTotal').textContent='₱'+php.toFixed(2);
    return;
  }
  document.getElementById('swapPreviewFrom').textContent=amount+' '+from;
  document.getElementById('swapPreviewRate').textContent=rateStr;
  document.getElementById('swapPreviewFee').textContent=fee+' '+from;
  document.getElementById('swapPreviewTotal').textContent=net.toFixed(6)+' '+to;
}

async function executeSwap(){
  var amount=parseFloat(document.getElementById('swapAmount').value);
  var from=document.getElementById('swapFrom').value;
  var to=document.getElementById('swapTo').value;
  if(!amount||amount<=0){showMsg('swapMsg','error','Enter a valid amount.');return;}
  if(from===to){showMsg('swapMsg','error','Select different tokens.');return;}
  showMsg('swapMsg','info','Processing swap...');
  var r=await api('/api/v1/swap/execute',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({fromToken:from,toToken:to,amount})
  });
  if(r.ok&&(r.data.success||r.data.referenceId)){
    showMsg('swapMsg','success','✅ Swap complete! Ref: '+(r.data.referenceId||'—'));
    document.getElementById('swapAmount').value='';
    document.getElementById('swapPreviewBox').style.display='none';
    loadBalance();
  }else{
    showMsg('swapMsg','error',r.data.error||r.data.message||'Swap failed.');
  }
}

// ── SEND PREVIEW ─────────────────────────────────────────────
function updatePreview(){
  var amount=parseFloat(document.getElementById('sendAmount').value);
  var currency=document.getElementById('sendCurrency').value;
  var box=document.getElementById('previewBox');
  if(!amount||amount<=0){box.style.display='none';return;}
  box.style.display='block';
  if(currency==='PHP'){
    document.getElementById('previewAmount').textContent='₱'+amount.toLocaleString();
    document.getElementById('previewRate').textContent='Internal PHP';
    document.getElementById('previewFee').textContent='₱'+(amount*0.005).toFixed(2);
    document.getElementById('previewTotal').textContent='₱'+(amount*0.995).toFixed(2);
    return;
  }
  var rate=liveRates[currency];
  if(!rate){box.style.display='none';showMsg('sendMsg','info','Rate for '+currency+' not available yet.');return;}
  var fee=parseFloat((amount*0.005).toFixed(6));
  var php=parseFloat(((amount-fee)*rate).toFixed(2));
  document.getElementById('previewAmount').textContent=amount+' '+currency;
  document.getElementById('previewRate').textContent='₱'+Number(rate).toLocaleString();
  document.getElementById('previewFee').textContent=fee+' '+currency;
  document.getElementById('previewTotal').textContent='₱'+Number(php).toLocaleString();
}

// ── SEND PAYMENT ──────────────────────────────────────────────
async function sendPayment(){
  var amount=parseFloat(document.getElementById('sendAmount').value);
  var currency=document.getElementById('sendCurrency').value;
  var notes=document.getElementById('sendNotes').value.trim();
  if(!amount||amount<=0){showMsg('sendMsg','error','Enter a valid amount.');return;}
  var activeMode='crypto';
  ['crypto','email','bill'].forEach(m=>{if(document.getElementById('mode-'+m).style.display!=='none')activeMode=m;});
  if(activeMode==='email'){
    var email=document.getElementById('receiverEmail').value.trim();
    if(!email){showMsg('sendMsg','error','Enter recipient email.');return;}
    var r2=await api('/api/v1/transfer/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({receiverEmail:email,amount})});
    if(r2.ok){showMsg('sendMsg','success','Sent! Ref: '+r2.data.referenceId);loadBalance();}
    else showMsg('sendMsg','error',r2.data.error||'Transfer failed.');
    return;
  }
  var body={amount,currency,notes};
  if(activeMode==='crypto'){
    body.senderAddress=document.getElementById('senderAddr').value.trim();
    body.receiverAddress=document.getElementById('receiverAddr').value.trim();
    if(!body.senderAddress||!body.receiverAddress){showMsg('sendMsg','error','Fill in both wallet addresses.');return;}
  }else{
    var biller=document.getElementById('billerType').value;
    var accNo=document.getElementById('billAccountNo').value.trim();
    if(!biller||!accNo){showMsg('sendMsg','error','Select biller and enter account number.');return;}
    body.senderAddress='ISCAN-BILLS';
    body.receiverAddress='BILLS-'+biller.toUpperCase();
    body.notes='Bill payment: '+biller+' — '+accNo;
  }
  var r=await api('/api/v1/remittance/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  if(r.ok){
    var tx=r.data.transaction;
    showMsg('sendMsg','success','Sent! Ref: '+tx.referenceId+(tx.phpEquivalent?' | Recipient gets ₱'+Number(tx.phpEquivalent).toLocaleString():''));
    document.getElementById('previewBox').style.display='none';
    document.getElementById('sendAmount').value='';
  }else showMsg('sendMsg','error',r.data.message||'Send failed.');
}

