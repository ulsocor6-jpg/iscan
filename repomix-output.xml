// ── QR ──────────────────────────────────────────────────────
var myAddress='',qrInstance=null;
async function loadMyWalletForQR(){
  var r=await api('/api/v1/wallet/list');
  var wallets=r.data&&r.data.wallets;
  if(wallets&&wallets.length>0){myAddress=wallets[0].address;renderQR(myAddress);}
