input,select{width:100%;padding:9px 11px;border-radius:8px;border:1px solid #1f2937;background:#0b1220;color:white;margin-top:7px;font-size:13px;outline:none;box-sizing:border-box;}
input:focus,select:focus{border-color:#3b82f6;}
select option{background:#0b1220;}
.btn{padding:9px 14px;border:none;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600;margin-top:8px;transition:all 0.2s;width:100%;}
.btn-primary{background:#2563eb;color:white;}
.btn-green{background:#16a34a;color:white;}
.btn-amber{background:#d97706;color:white;}
.btn-red{background:#dc2626;color:white;}
.btn-sm{padding:5px 10px;font-size:11px;width:auto;margin-top:0;}
.btn-icon{background:#1f2937;color:white;border:1px solid #374151;padding:9px 14px;border-radius:8px;cursor:pointer;font-size:13px;margin-right:6px;margin-top:8px;transition:all 0.2s;}
.btn-icon:hover{border-color:#3b82f6;color:#60a5fa;}
.btn-unlink{background:#450a0a;color:#f87171;border:1px solid #7f1d1d;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;transition:all 0.2s;}
.btn-unlink:hover{background:#7f1d1d;color:white;}
.msg{margin-top:8px;padding:9px 12px;border-radius:8px;font-size:12px;display:none;}
.msg.success{background:#064e3b;color:#34d399;display:block;}
.msg.error{background:#450a0a;color:#f87171;display:block;}
.msg.info{background:#1e3a5f;color:#60a5fa;display:block;}
.ledger-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px;}
.ledger-table th{text-align:left;padding:8px 10px;color:#6b7280;border-bottom:1px solid #1f2937;font-weight:500;font-size:11px;text-transform:uppercase;}
.ledger-table td{padding:9px 10px;border-bottom:1px solid #0f172a;}
.ledger-table tr:hover td{background:#0f172a;}
.debit{color:#f87171;font-weight:600;}
