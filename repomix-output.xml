  var iscanAddr=r.data.iscanAddress||'—';
  var oEl=document.getElementById('iscanAddrDisplay');
  if(oEl)oEl.textContent=iscanAddr;
  var el=document.getElementById('walletOverview');
  if(wallets.length===0){
    el.innerHTML='<div style="color:#6b7280;font-size:12px;">No wallet connected — go to <strong style="color:#60a5fa;cursor:pointer;" onclick="switchTab(\'wallets\',null)">Wallets tab</strong></div>';
    return;
  }
  var w=wallets[0];
  var chainInfo=CHAIN_MAP[w.chainId]||{name:'Unknown',token:'?',color:'#94a3b8'};
  el.innerHTML=
    '<div class="token-row"><div class="token-label"><span class="token-dot" style="background:'+chainInfo.color+'"></span>'+chainInfo.token+'</div><span class="token-val">'+(w.nativeBalance||0)+' '+chainInfo.token+'</span></div>'+
    '<div class="token-row"><div class="token-label"><span class="token-dot" style="background:#2775ca"></span>USDC</div><span class="token-val">'+(w.usdcBalance||0)+' USDC</span></div>'+
    '<div style="margin-top:8px;font-size:11px;color:#6b7280;">Network: '+chainInfo.name+' | <span class="wallet-addr">'+w.address.substring(0,10)+'...'+w.address.substring(w.address.length-6)+'</span></div>';
}

// ── USDC BALANCE ────────────────────────────────────────────
async function getUSDCBalance(provider,address,chainId){
  var contract=USDC_CONTRACTS[chainId];
  if(!contract)return 0;
  try{
    var data='0x70a08231000000000000000000000000'+address.slice(2).padStart(64,'0');
    var result=await provider.request({method:'eth_call',params:[{to:contract,data},'latest']});
    return parseInt(result,16)/1e6;
  }catch(e){return 0;}
}

// ── CONNECT WALLET (MetaMask only — uses window.ethereum) ───
async function connectWallet(type){
  // ── MetaMask: always use window.ethereum, never a custom RPC ──
  if(type!=='metamask'){
    showMsg('walletMsg','error','Only MetaMask is supported at this time.');
    return;
  }

  if(!window.ethereum){
    showMsg('walletMsg','error','MetaMask not detected. Please install MetaMask from metamask.io and refresh.');
    return;
  }

  // If multiple wallets injected, prefer MetaMask
  var provider=null;
  if(window.ethereum.providers){
    provider=window.ethereum.providers.find(p=>p.isMetaMask)||null;
  }
  if(!provider&&window.ethereum.isMetaMask){
    provider=window.ethereum;
  }
  if(!provider){
    showMsg('walletMsg','error','MetaMask not detected. Please install MetaMask from metamask.io.');
    return;
  }

  try{
    showMsg('walletMsg','info','Connecting to MetaMask...');

    // Request accounts — this opens the MetaMask popup
    var accounts=await provider.request({method:'eth_requestAccounts'});
    if(!accounts||accounts.length===0){
      showMsg('walletMsg','error','No accounts returned from MetaMask.');
      return;
    }
    var address=accounts[0];

    // Get chain
    var chainId=await provider.request({method:'eth_chainId'});
    var chainInfo=CHAIN_MAP[chainId]||{name:'Unknown Network',token:'ETH',color:'#94a3b8'};

    // Native balance
    var bw=await provider.request({method:'eth_getBalance',params:[address,'latest']});
    var nativeBal=(parseInt(bw,16)/1e18).toFixed(4);

    // USDC balance
    var usdcBal=await getUSDCBalance(provider,address,chainId);

    // Save to backend
    var r=await api('/api/v1/wallet/link',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({address,provider:'metamask',chainId,nativeBalance:parseFloat(nativeBal),nativeToken:chainInfo.token,usdcBalance:usdcBal})
    });

    if(r.ok||r.data.success){
      showMsg('walletMsg','success',
        '✅ '+chainInfo.name+' connected: '+address.substring(0,6)+'...'+address.substring(address.length-4)+
        ' | '+nativeBal+' '+chainInfo.token+
        (usdcBal>0?' | '+usdcBal.toFixed(2)+' USDC':'')
      );
      if(r.data.iscanAddress){
        myIscanAddress=r.data.iscanAddress;
        var wEl=document.getElementById('iscanAddrWallet');if(wEl)wEl.textContent=myIscanAddress;
        var oEl=document.getElementById('iscanAddrDisplay');if(oEl)oEl.textContent=myIscanAddress;
        var iEl=document.getElementById('myIscanAddr');if(iEl)iEl.textContent=myIscanAddress;
        var rEl=document.getElementById('receiveIscanAddr');if(rEl)rEl.textContent=myIscanAddress;
        renderIscanQR(myIscanAddress);
      }
      myAddress=address;
      loadWallets();
      loadWalletsForOverview();
    }else{
      showMsg('walletMsg','error',r.data.error||'Failed to link wallet.');
    }
  }catch(err){
    if(err.code===4001){
      showMsg('walletMsg','error','Connection rejected. Please approve the MetaMask request.');
    }else{
      showMsg('walletMsg','error','MetaMask error: '+err.message);
    }
  }
}

