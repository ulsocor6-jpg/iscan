    r.data.entries.map(e=>'<tr>'+
      '<td style="color:#94a3b8;">'+e.transactionType+'</td>'+
      '<td class="debit">'+(e.debit>0?'₱'+Number(e.debit).toLocaleString('en',{minimumFractionDigits:2}):'—')+'</td>'+
      '<td class="credit">'+(e.credit>0?'₱'+Number(e.credit).toLocaleString('en',{minimumFractionDigits:2}):'—')+'</td>'+
      '<td class="ref">'+e.referenceId+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+e.description+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+new Date(e.createdAt).toLocaleString()+'</td>'+
      '<td><span class="badge '+e.status+'">'+e.status.toUpperCase()+'</span></td>'+
    '</tr>').join('')+'</tbody></table>';
}

async function loadOnrampHistory(){
  var el=document.getElementById('ledgerContent');
  el.innerHTML='<p style="color:#6b7280;font-size:12px;">Loading crypto onramp history…</p>';
  var r=await api('/api/v1/onramp/history');
  if(!r.ok||!r.data.entries||r.data.entries.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No crypto onramp transactions yet.</p>';return;}
  el.innerHTML='<div style="margin-bottom:8px;font-size:11px;color:#2de8a2;font-weight:600;">🪙 Showing crypto onramp entries only</div>'+
    '<table class="ledger-table"><thead><tr><th>Token</th><th>USD</th><th>PHP Rate</th><th>Fee</th><th>Net PHP</th><th>Channel</th><th>Reference</th><th>Date</th><th>Status</th></tr></thead><tbody>'+
    r.data.entries.map(function(e){
      var desc=e.description||'';
      var tokenMatch=desc.match(/^(USDC|USDT)/);var token=tokenMatch?tokenMatch[1]:'—';
      var rateMatch=desc.match(/Rate: ₱([\d.]+)/);var rate=rateMatch?'₱'+rateMatch[1]:'—';
      var chanMatch=desc.match(/via (\w+)/);var chan=chanMatch?chanMatch[1]:'—';
      return '<tr>'+
        '<td><span class="badge" style="background:'+(token==='USDC'?'#1a3a5c':'#1a3d2e')+';color:'+(token==='USDC'?'#60a5fa':'#34d399')+'">'+token+'</span></td>'+
        '<td style="color:#f9fafb;font-weight:600;">'+(e.amount&&rate!=='—'?'$'+(e.amount/(parseFloat(rate.replace('₱',''))||1)).toFixed(2):'—')+'</td>'+
        '<td style="color:#94a3b8;font-size:11px;">'+rate+'</td>'+
        '<td style="color:#f87171;font-size:11px;">'+(e.feePHP?'₱'+Number(e.feePHP).toLocaleString('en',{minimumFractionDigits:2}):'—')+'</td>'+
        '<td class="credit">₱'+Number(e.amount||0).toLocaleString('en',{minimumFractionDigits:2})+'</td>'+
        '<td style="color:#94a3b8;font-size:11px;text-transform:capitalize;">'+chan+'</td>'+
        '<td class="ref">'+e.referenceId+'</td>'+
        '<td style="color:#6b7280;font-size:11px;">'+new Date(e.createdAt).toLocaleString()+'</td>'+
        '<td><span class="badge '+e.status+'">'+e.status.toUpperCase()+'</span></td>'+
      '</tr>';
    }).join('')+'</tbody></table>';
}

async function loadRecentLedger(){
  var r=await api('/api/v1/ledger/history'),el=document.getElementById('recentLedger');
  if(!r.ok||!r.data.entries||r.data.entries.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No activity yet.</p>';return;}
  el.innerHTML=r.data.entries.slice(0,5).map(e=>{
    var c=e.credit>0;
    return '<div class="activity-row">'+
      '<div><span style="color:#94a3b8;">'+e.transactionType+'</span> <span class="ref"> '+e.referenceId+'</span></div>'+
      '<span class="'+(c?'credit':'debit')+'">'+(c?'+':'−')+'₱'+Number(c?e.credit:e.debit).toLocaleString()+'</span>'+
    '</div>';
  }).join('');
}

// ── SETTLEMENT ────────────────────────────────────────────────
async function loadPending(){
  var r=await api('/api/v1/remittance/pending'),el=document.getElementById('pendingList');
  if(!r.ok||!r.data.transactions||r.data.transactions.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No pending settlements.</p>';return;}
  el.innerHTML='<table class="ledger-table"><thead><tr><th>Reference</th><th>Amount</th><th>PHP Value</th><th>Date</th><th>Action</th></tr></thead><tbody>'+
    r.data.transactions.map(tx=>'<tr>'+
      '<td class="ref">'+tx.referenceId+'</td>'+
      '<td>'+tx.amount+' '+tx.currency+'</td>'+
      '<td class="credit">₱'+Number(tx.phpEquivalent||0).toLocaleString()+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+new Date(tx.createdAt).toLocaleDateString()+'</td>'+
      '<td><button class="btn btn-green btn-sm" onclick="settleNow(\''+tx._id+'\')">Settle</button></td>'+
    '</tr>').join('')+'</tbody></table>';
}
async function settleNow(id){
  var phone=prompt('Recipient Coins.ph phone (e.g. 09171234567):');
  if(!phone)return;
  var r=await api('/api/v1/remittance/settle/'+id,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({recipientPhone:phone})});
  alert(r.ok?(r.data.result&&r.data.result.mock?'Queued (Coins.ph API pending)':'Settled!'):'Failed: '+(r.data&&r.data.message));
  if(r.ok)loadPending();
}

// ── AUDIT ─────────────────────────────────────────────────────
async function loadAudit(){
  var r=await api('/api/v1/remittance/audit'),el=document.getElementById('auditList');
  if(!r.ok||!r.data.logs||r.data.logs.length===0){el.innerHTML='<p style="color:#6b7280;font-size:12px;">No records yet.</p>';return;}
  el.innerHTML='<table class="ledger-table"><thead><tr><th>Action</th><th>Entity</th><th>Reference</th><th>Timestamp</th><th>Status</th></tr></thead><tbody>'+
    r.data.logs.map(l=>'<tr>'+
      '<td style="color:#c084fc;font-weight:600;">'+l.action+'</td>'+
      '<td style="color:#94a3b8;">'+l.entity+'</td>'+
      '<td class="ref">'+(l.details&&l.details.referenceId?l.details.referenceId:'—')+'</td>'+
      '<td style="color:#6b7280;font-size:11px;">'+new Date(l.createdAt).toLocaleString()+'</td>'+
      '<td><span class="badge '+(l.status||'success')+'">'+l.status.toUpperCase()+'</span></td>'+
    '</tr>').join('')+'</tbody></table>';
}

// ── ACCOUNTS ──────────────────────────────────────────────────
function loadProfile(){
  document.getElementById('profileInfo').innerHTML=
    '<div><strong>Email:</strong> '+userEmail+'</div>'+
    '<div><strong>Name:</strong> '+(userName||'—')+'</div>';
  document.getElementById('kycStatus').innerHTML=
    '<span class="badge pending">UNVERIFIED</span>'+
    '<p style="margin-top:6px;color:#6b7280;font-size:11px;">Upload a government ID to verify and unlock higher limits.</p>';
}
async function uploadKYC(e){
  var file=e.target.files[0];if(!file)return;
  var fd=new FormData();fd.append('image',file);
  var res=await fetch('/api/v1/kyc/upload-id',{method:'POST',credentials:'same-origin',body:fd});
  var d=await res.json();
  showMsg('kycMsg',d.success?'success':'error',d.success?'ID uploaded.':d.error||'Failed.');
}
async function addBank(){
  var bN=document.getElementById('bankName').value.trim();
  var aN=document.getElementById('accountName').value.trim();
  var aNo=document.getElementById('accountNumber').value.trim();
  if(!bN||!aN||!aNo){showMsg('bankMsg','error','Fill all fields.');return;}
  var r=await api('/api/v1/bank/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({bankName:bN,accountName:aN,accountNumber:aNo})});
  if(r.ok){showMsg('bankMsg','success','Bank added.');document.getElementById('bankName').value='';document.getElementById('accountName').value='';document.getElementById('accountNumber').value='';loadBanks();}
  else showMsg('bankMsg','error',r.data.error||'Failed.');
}
async function loadBanks(){
  var r=await api('/api/v1/bank/list'),el=document.getElementById('bankList');
  if(!r.ok||!r.data.banks||r.data.banks.length===0){el.innerHTML='<p style="color:#6b7280;font-size:11px;margin-top:6px;">No banks linked.</p>';return;}
  el.innerHTML=r.data.banks.map(b=>'<div class="wallet-item"><div><strong>'+b.bankName+'</strong><br><span style="color:#6b7280;font-size:11px;">'+b.accountName+' — '+b.accountNumber+'</span></div></div>').join('');
}

// ── INIT ──────────────────────────────────────────────────────
loadRates();
setInterval(loadRates,60000);
loadBalance();
loadRecentLedger();
loadWalletsForOverview();
// Pre-load ISCAN address so it's ready everywhere
loadIscanAddressAll();
// Init token selector for default chain (Ethereum)
updateTokenSelectorForChain('0x1');
</script>
</body>
</html>
</file>

