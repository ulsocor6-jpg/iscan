        <select id="dep-chain">
          <option value="tron">TRON (USDT TRC20)</option>
        </select>
        <button class="btn btn-primary" id="dep-btn" onclick="generateDepositAddress()">Generate Gateway Address</button>
        <div id="dep-status" class="msg"></div>
        
        <div id="dep-box" style="display:none; margin-top:12px; background:#0b1220; padding:12px; border-radius:8px; border:1px solid #1f2937;">
          <p style="font-size:11px; color:#94a3b8; margin-bottom:4px;">Deploy Funds Directly To:</p>
          <input id="dep-address" readonly style="font-family:monospace; font-size:12px; color:#60a5fa; text-align:center;">
          <button class="btn btn-sm btn-green" style="width:100%; margin-top:8px;" onclick="copyDepositAddress()">Copy Token Address</button>
          <p id="dep-wait" style="color:#fcd34d; font-size:11px; margin-top:8px; text-align:center;">
            ⏳ Monitoring network blocks for changes...
          </p>
        </div>
      </div>

      <div class="card">
        <h3>⚡ Internal Routing Handle</h3>
        <div style="text-align:center;">
          <div id="receiveIscanAddr" class="iscan-addr" style="margin-bottom:8px;">Loading...</div>
          <canvas id="iscanQrCanvas" width="140" height="140"></canvas>
        </div>
      </div>
    </div>
  </div>

  <div id="crypto-cashin-tab" class="sub-screen">
    <div class="card" style="max-width:500px; margin:auto;">
      <h3>🪙 Direct Conversion Window</h3>
      <p style="color:#6b7280;font-size:12px;">Convert incoming stable assets directly into retail PH channels.</p>
      
      <span class="step-label">1. Asset Designation</span>
      <div class="token-selector">
        <button class="token-btn active" onclick="selectToken('USDC', this)">USDC</button>
        <button class="token-btn" onclick="selectToken('USDT', this)">USDT</button>
      </div>

      <span class="step-label">2. Target Rail</span>
      <div class="channel-selector">
        <button class="channel-btn active" onclick="selectChannel('maya', this)">Maya (1.5%)</button>
        <button class="channel-btn" onclick="selectChannel('gcash', this)">GCash (2.0%)</button>
      </div>

      <span class="step-label">3. Transaction Value</span>
      <input id="or-usd-amount" type="number" min="1" step="0.01" placeholder="0.00 USD" oninput="updateBreakdown()">

      <div class="preview-box" id="or-breakdown">
        <div class="preview-row"><span>Gross Conversion</span><span id="bd-gross">₱0.00</span></div>
        <div class="preview-row"><span>Processor Deduction</span><span id="bd-fee">₱0.00</span></div>
        <div class="preview-total"><span>Disbursed Net</span><span id="bd-net">₱0.00</span></div>
      </div>

      <span class="step-label">4. Destination Mobile Account</span>
      <input id="or-mobile" type="tel" placeholder="9XXXXXXXXX" maxlength="10">

      <span class="step-label">5. Settlement Verification Path (Optional)</span>
      <input id="or-txhash" type="text" placeholder="Paste structural hash if pre-executed on-chain">

      <button class="btn btn-primary" id="or-submit-btn" style="margin-top:14px;" onclick="submitConversion()">Execute Settlement Wire</button>
      <div id="or-status" class="msg"></div>
    </div>
  </div>
</div>

<div id="ledger" class="screen">
  <div class="card">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
      <h3>📒 Account Ledger Balance: <span id="ledgerBalance" style="color:#22c55e;">₱0.00</span></h3>
    </div>
    <div id="ledgerContent"></div>
  </div>
</div>

<div id="wallets" class="screen">
  <div class="card">
    <h3>🔗 Linked Web3 Hardware & Nodes</h3>
    <button class="btn btn-primary" style="width:auto;" onclick="connectMetaMask()">Link Active MetaMask Account</button>
    <div id="walletMsg" class="msg"></div>
    <div id="walletList" style="margin-top:12px;"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
// Global State Storage Objects
var ISCAN_STATE = {
  depositPolling: null,
  activeToken: 'USDC',
  activeChannel: 'maya',
  conversionRate: 58.45
};

function getCookie(name) {
  var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
  return match ? decodeURIComponent(match[2]) : null;
}

function showMsg(elementId, statusType, displayMessage) {
  var target = document.getElementById(elementId);
  if (!target) return;
  target.textContent = displayMessage;
  target.className = 'msg ' + statusType;
  target.style.display = 'block';
}

async function api(endpoint, options) {
  try {
    var response = await fetch(endpoint, Object.assign({ credentials: 'same-origin' }, options || {}));
    var textData = await response.text();
    try {
      var jsonData = JSON.parse(textData);
      return { ok: response.ok, data: jsonData };
    } catch(e) {
      return { ok: response.ok, data: { message: textData } };
    }
  } catch(err) {
    return { ok: false, data: { message: err.message } };
  }
}

// Global Balance Synchronization Engine
async function loadBalance() {
  // Update internal routing statement details
  var historyReq = await api('/api/v1/ledger/history');
  if (historyReq.ok && historyReq.data) {
    var computedBal = historyReq.data.balance || 0;
    var safeFormatted = '₱' + Number(computedBal).toLocaleString('en', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById('iscanBalance').textContent = safeFormatted;
    document.getElementById('ledgerBalance').textContent = safeFormatted;
  }

  // Synchronize custodial systems
  var walletReq = await api('/api/v1/wallet');
  if (walletReq.ok && walletReq.data && walletReq.data.success) {
    var internalCustodial = walletReq.data.data.balance || 0;
    document.getElementById('wallet-balance').textContent = Number(internalCustodial).toFixed(2);
  }
}

// Live Rates Dispatcher
async function loadRates() {
  var rateReq = await api('/api/v1/remittance/rates');
  if (rateReq.ok && rateReq.data && rateReq.data.rates) {
    var source = rateReq.data.rates;
    ISCAN_STATE.conversionRate = parseFloat(source.USDT || source.USDC || 58.45);
    document.getElementById('rateUSDC').textContent = '₱' + Number(source.USDC || 58.45).toFixed(2);
    document.getElementById('rateUSDT').textContent = '₱' + Number(source.USDT || 58.42).toFixed(2);
    document.getElementById('rateTime').textContent = 'Sync Timestamp: ' + new Date().toLocaleTimeString();
  } else {
    // Structural static safe fallbacks if server hasn't mapped rate queries yet
    document.getElementById('rateUSDC').textContent = '₱' + ISCAN_STATE.conversionRate.toFixed(2);
    document.getElementById('rateUSDT').textContent = '₱' + (ISCAN_STATE.conversionRate - 0.03).toFixed(2);
  }
}

// Navigation & Screen Control Hub
function switchTab(screenId, triggerButton) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-left button').forEach(b => b.classList.remove('active'));
  document.getElementById(screenId).classList.add('active');
  if (triggerButton) triggerButton.classList.add('active');
  
  if (screenId === 'overview') { loadBalance(); loadRates(); }
  if (screenId === 'ledger') { fetchAndRenderLedger(); }
}

function switchSub(subTabId, triggerButton) {
  document.querySelectorAll('.sub-screen').forEach(s => s.classList.remove('active'));
  triggerButton.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('active'));
  document.getElementById(subTabId).classList.add('active');
  triggerButton.classList.add('active');
}

// TRC20 Gateway Functions
async function generateDepositAddress() {
  var actionBtn = document.getElementById('dep-btn');
  actionBtn.disabled = true; 
  actionBtn.textContent = 'Mapping Contract Routing...';
  showMsg('dep-status', 'info', 'Querying decentralized ledger network allocations...');

  var req = await api('/api/v1/onramp/deposit-address', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ chain: document.getElementById('dep-chain').value, token: 'USDT' })
  });

  actionBtn.disabled = false; 
  actionBtn.textContent = 'Generate Gateway Address';

  if (req.ok && req.data && req.data.success) {
    document.getElementById('dep-box').style.display = 'block';
    document.getElementById('dep-address').value = req.data.data.address;
    showMsg('dep-status', 'success', 'Unique TRC20 ingestion point assigned.');

    if (ISCAN_STATE.depositPolling) clearInterval(ISCAN_STATE.depositPolling);
    ISCAN_STATE.depositPolling = setInterval(loadBalance, 4000);
  } else {
    showMsg('dep-status', 'error', (req.data ? req.data.message : 'Allocation query error. Verify configurations.'));
  }
}

function copyDepositAddress() {
  var copyValue = document.getElementById('dep-address').value;
  if(!copyValue) return;
  navigator.clipboard.writeText(copyValue);
  showMsg('dep-status', 'success', 'Address copied to local workstation clipboard.');
}

// Onramp Flow Parameters
function selectToken(tokenTicker, el) {
  ISCAN_STATE.activeToken = tokenTicker;
  el.parentElement.querySelectorAll('.token-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  updateBreakdown();
}

function selectChannel(channelId, el) {
  ISCAN_STATE.activeChannel = channelId;
  el.parentElement.querySelectorAll('.channel-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  updateBreakdown();
}

function updateBreakdown() {
  var rawInput = parseFloat(document.getElementById('or-usd-amount').value) || 0;
  var displayBox = document.getElementById('or-breakdown');
  if (rawInput <= 0) { displayBox.style.display = 'none'; return; }

  var computedGross = rawInput * ISCAN_STATE.conversionRate;
  var feePercentage = (ISCAN_STATE.activeChannel === 'maya') ? 0.015 : 0.020;
  var feeDeduction = computedGross * feePercentage;
  var finalNetValue = computedGross - feeDeduction;

  document.getElementById('bd-gross').textContent = '₱' + computedGross.toFixed(2);
  document.getElementById('bd-fee').textContent = '-₱' + feeDeduction.toFixed(2);
  document.getElementById('bd-net').textContent = '₱' + finalNetValue.toFixed(2);
  displayBox.style.display = 'block';
}

async function submitConversion() {
  var inputAmount = parseFloat(document.getElementById('or-usd-amount').value);
  var inputMobile = document.getElementById('or-mobile').value.trim();
  var inputTxHash = document.getElementById('or-txhash').value.trim();

  if (!inputAmount || inputAmount < 1) return showMsg('or-status', 'error', 'Error: Ingestion threshold must equal or exceed $1.00 USD.');
  if (!/^9\d{9}$/.test(inputMobile)) return showMsg('or-status', 'error', 'Error: Target account input format must equal 9XXXXXXXXX.');

  var packagePayload = {
    token: ISCAN_STATE.activeToken,
    usdAmount: inputAmount,
    channel: ISCAN_STATE.activeChannel,
    mobileNumber: '+63' + inputMobile
  };

  if (inputTxHash) {
    packagePayload.txHash = inputTxHash;
  } else {
    packagePayload.depositId = crypto.randomUUID();
  }

  var submissionButton = document.getElementById('or-submit-btn');
  submissionButton.disabled = true;
  submissionButton.textContent = 'Verifying Fluidity & Reserves...';
  showMsg('or-status', 'info', 'Transmitting liquidity request parameters...');

  var req = await api('/api/v1/onramp/convert', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(packagePayload)
  });

  submissionButton.disabled = false;
  submissionButton.textContent = 'Execute Settlement Wire';

  if (req.ok && req.data && req.data.success) {
    var displayReturnAmount = req.data.netPHP || (req.data.data ? req.data.data.phpAmount : 0) || 0;
    showMsg('or-status', 'success', 'Processing Complete: ₱' + Number(displayReturnAmount).toFixed(2) + ' routed out successfully.');
    loadBalance();
  } else {
    showMsg('or-status', 'error', 'Execution Error: ' + ((req.data && req.data.message) ? req.data.message : 'Server reject. Check validation parameters.'));
  }
}

// Setup Basic Ledger Data Fetching loops
async function fetchAndRenderLedger() {
  var container = document.getElementById('ledgerContent');
  container.innerHTML = '<p style="color:#6b7280;font-size:12px;">Reading activity structures...</p>';
  var req = await api('/api/v1/ledger/history');
  if(req.ok && req.data && req.data.history) {
    if(req.data.history.length === 0) {
      container.innerHTML = '<p style="color:#6b7280;font-size:12px;">No historic movements found for user profile context.</p>';
      return;
    }
    var htmlTable = '<table class="ledger-table"><thead><tr><th>Timestamp</th><th>Description</th><th>Delta</th></tr></thead><tbody>';
    req.data.history.forEach(item => {
      htmlTable += '<tr><td>' + new Date(item.createdAt || Date.now()).toLocaleString() + '</td><td>' + (item.description || 'System Entry') + '</td><td style="color:' + (item.amount >= 0 ? '#34d399' : '#f87171') + '">' + (item.amount >= 0 ? '+' : '') + item.amount + '</td></tr>';
    });
    htmlTable += '</tbody></table>';
    container.innerHTML = htmlTable;
  } else {
    container.innerHTML = '<p style="color:#6b7280;font-size:12px;">Ledger query offline. Data structures unchanged.</p>';
  }
}

// Hardware Wallet Mapping
async function connectMetaMask() {
  if (!window.ethereum) return showMsg('walletMsg', 'error', 'Web3 integration layer absent. Injected provider missing.');
  try {
    var accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
    if(accounts.length > 0) {
      showMsg('walletMsg', 'success', 'Linked signature layer via account node: ' + accounts[0]);
    }
  } catch(e) {
    showMsg('walletMsg', 'error', 'User rejected interaction request.');
  }
}

// App Lifespans Init
(function Initialization() {
  var contextEmail = getCookie('iscan_email') || 'sandbox-user@iscan.network';
  document.getElementById('userInfo').textContent = contextEmail;
  document.getElementById('iscanAddrDisplay').textContent = 'ISCAN-' + btoa(contextEmail).substring(0,12).toUpperCase();
  document.getElementById('receiveIscanAddr').textContent = document.getElementById('iscanAddrDisplay').textContent;
  
  try {
    new QRCode(document.getElementById("iscanQrCanvas"), {
      text: document.getElementById('iscanAddrDisplay').textContent,
      width: 140,
      height: 140
    });
  } catch(e) {}

  loadBalance();
  loadRates();
  setInterval(loadRates, 30000);
})();
</script>
</body>
</html>
