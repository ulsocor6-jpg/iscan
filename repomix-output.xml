.wallet-tokens{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
.token-chip{background:#1f2937;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;}
.iscan-box{background:linear-gradient(135deg,#1e3a5f,#0f172a);border:1px solid #2563eb;border-radius:10px;padding:12px;margin-top:8px;}
.iscan-addr{font-family:monospace;font-size:13px;color:#60a5fa;word-break:break-all;margin-top:4px;font-weight:700;letter-spacing:0.5px;}
.preview-box{background:#0b1220;border:1px solid #374151;border-radius:8px;padding:10px;margin-top:10px;font-size:12px;display:none;}
.preview-row{display:flex;justify-content:space-between;padding:3px 0;color:#94a3b8;}
.preview-row span:last-child{color:#f9fafb;font-weight:600;}
.preview-total{border-top:1px solid #1f2937;margin-top:6px;padding-top:6px;display:flex;justify-content:space-between;color:#22c55e;font-weight:700;font-size:14px;}
.tab-group{display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap;}
.tab-group button{flex:1;min-width:90px;padding:8px;border:1px solid #1f2937;background:transparent;color:#94a3b8;border-radius:8px;cursor:pointer;font-size:12px;}
.tab-group button.active{background:#2563eb;border-color:#2563eb;color:white;}
.sub-screen{display:none;}
.sub-screen.active{display:block;}
.activity-row{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #1f2937;font-size:12px;}
.activity-row:last-child{border:none;}
.network-badge{font-size:10px;padding:2px 7px;border-radius:12px;font-weight:600;background:#1f2937;color:#94a3b8;}
.chain-btn{padding:6px 12px;border:1px solid #1f2937;background:#0b1220;color:#94a3b8;border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;transition:all .15s;}
.chain-btn.active{border-color:#2563eb;background:#1e3a5f;color:#60a5fa;}
.chain-btn:hover{border-color:#3b82f6;color:white;}
/* ── ISCAN receive panel ── */
.iscan-receive-panel{background:linear-gradient(135deg,#0f2744,#111827);border:1px solid #2563eb;border-radius:12px;padding:20px;text-align:center;}
.iscan-receive-addr{font-family:monospace;font-size:15px;color:#60a5fa;word-break:break-all;margin:12px 0;font-weight:700;letter-spacing:0.5px;background:#0b1220;padding:10px 14px;border-radius:8px;border:1px solid #1f2937;}
/* ── CSS variables for crypto panel ── */
:root{--border:#1f2937;--surface2:#111827;--muted:#6b7280;--accent:#2de8a2;--text:#f9fafb;}
.input-wrap{display:flex;align-items:center;border:1px solid var(--border);border-radius:8px;background:#0b1220;overflow:hidden;margin-top:0;}
.input-wrap input{border:none;background:transparent;margin-top:0;flex:1;}
.input-wrap input:focus{outline:none;border:none;box-shadow:none;}
.input-prefix{padding:9px 10px;color:var(--muted);font-size:13px;border-right:1px solid var(--border);background:#0f172a;white-space:nowrap;}
#crypto-onramp-panel .btn-primary{width:100%;padding:11px;font-size:14px;font-weight:700;border-radius:8px;cursor:pointer;border:none;background:#2563eb;color:white;margin-top:0;transition:background .15s;}
#crypto-onramp-panel .btn-primary:hover{background:#1d4ed8;}
#crypto-onramp-panel .btn-primary:disabled{opacity:.55;cursor:not-allowed;}
</style>
</head>
<body>

<nav>
  <div class="nav-left">
    <button class="active" onclick="switchTab('overview',this)">Dashboard</button>
    <button onclick="switchTab('pay',this)">Pay & Receive</button>
    <button onclick="switchTab('ledger',this)">Ledger</button>
    <button onclick="switchTab('settlement',this)">Settlement</button>
    <button onclick="switchTab('audit',this)">Audit Trail</button>
    <button onclick="switchTab('accounts',this)">Accounts</button>
    <button onclick="switchTab('wallets',this)">Wallets</button>
  </div>
  <div class="nav-right">
    <span id="userInfo">—</span>
    <button class="btn-logout" onclick="handleLogout()">Sign Out</button>
  </div>
</nav>

<!-- OVERVIEW -->
<div id="overview" class="screen active">
  <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;margin-bottom:14px;">
    <div class="card" style="background:linear-gradient(135deg,#0f2744,#111827);border-color:#2563eb;">
      <h3 style="color:#93c5fd;">💰 ISCAN Balance</h3>
      <div class="balance-big" id="iscanBalance">₱0.00</div>
      <div class="balance-sub">Available PHP balance</div>
      <div style="display:flex;gap:8px;margin-top:14px;">
        <button class="btn btn-green btn-sm" style="flex:1;margin-top:0;" onclick="switchTab('pay',document.querySelector('[onclick*=pay]'))">➕ Cash In</button>
        <button class="btn btn-amber btn-sm" style="flex:1;margin-top:0;" onclick="switchTab('pay',document.querySelector('[onclick*=pay]'))">➖ Cash Out</button>
        <button class="btn btn-primary btn-sm" style="flex:1;margin-top:0;" onclick="switchTab('pay',document.querySelector('[onclick*=pay]'))">↔ Transfer</button>
      </div>
      <div class="iscan-box" style="margin-top:12px;">
        <div style="font-size:11px;color:#94a3b8;">Your ISCAN Address</div>
        <div class="iscan-addr" id="iscanAddrDisplay">—</div>
        <button class="btn btn-sm" style="margin-top:8px;background:#1e3a5f;color:#60a5fa;border:1px solid #2563eb;width:auto;padding:4px 12px;" onclick="navigator.clipboard.writeText(document.getElementById('iscanAddrDisplay').textContent).then(()=>this.textContent='Copied!').catch(()=>{})">Copy Address</button>
      </div>
    </div>
    <div class="card">
      <h3>💳 Quick Cash In</h3>
      <p style="color:#6b7280;font-size:12px;margin-bottom:8px;">Deposit PHP via GCash or debit/credit card instantly.</p>
      <input id="quickCashinAmount" type="number" placeholder="Amount (PHP) — min ₱20" min="20" max="100000" style="margin-top:4px;">
      <button class="btn btn-green" style="margin-top:10px;" onclick="quickCashIn()">Generate Payment Link</button>
      <div id="quickCashinMsg" class="msg"></div>
    </div>
    <div class="card">
      <h3>📈 Live Rates (PHP)</h3>
      <div class="rate-row"><span>USDC</span><span class="rate-val" id="rateUSDC">Loading...</span></div>
      <div class="rate-row"><span>ETH</span><span class="rate-val" id="rateETH">Loading...</span></div>
      <div class="rate-row"><span>RON</span><span class="rate-val" id="rateRON">Loading...</span></div>
      <div style="font-size:10px;color:#6b7280;margin-top:6px;" id="rateTime"></div>
      <div style="border-top:1px solid #1f2937;margin-top:12px;padding-top:12px;">
        <h3 style="margin-bottom:8px;">🔗 Connected Wallet</h3>
        <div id="walletOverview"><div style="color:#6b7280;font-size:12px;">No wallet connected — go to <span style="color:#60a5fa;cursor:pointer;" onclick="switchTab('wallets',null)">Wallets tab</span></div></div>
      </div>
    </div>
  </div>
  <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <h3>📊 Recent Activity</h3>
      <button class="btn btn-sm" style="background:#1f2937;color:#94a3b8;border:1px solid #374151;width:auto;margin-top:0;" onclick="switchTab('ledger',null)">View All →</button>
    </div>
    <div id="recentLedger"><p style="color:#6b7280;font-size:12px;">No activity yet.</p></div>
  </div>
</div>

<!-- PAY & RECEIVE -->
<div id="pay" class="screen">
  <div class="tab-group">
    <button class="active" onclick="switchSub('send-tab',this)">📤 Send / Pay</button>
    <button onclick="switchSub('receive-tab',this)">📥 Receive</button>
    <button onclick="switchSub('scan-tab',this)">📷 Scan QR</button>
    <button onclick="switchSub('iscan-tab',this)">⚡ ISCAN Transfer</button>
    <button onclick="switchSub('cashin-tab',this)">💳 Cash In</button>
    <button onclick="switchSub('crypto-cashin-tab',this)">🪙 Crypto Cash In</button>
  </div>

  <!-- SEND -->
  <div id="send-tab" class="sub-screen active">
    <div class="grid">
      <div class="card">
        <h3>Send Remittance</h3>
        <div class="tab-group">
          <button class="active" onclick="switchMode('crypto',this)">Crypto</button>
          <button onclick="switchMode('email',this)">By Email</button>
          <button onclick="switchMode('bill',this)">Bills</button>
        </div>
        <div id="mode-crypto">
          <input id="senderAddr" placeholder="Your wallet address">
          <input id="receiverAddr" placeholder="Recipient wallet address">
        </div>
        <div id="mode-email" style="display:none;">
          <input id="receiverEmail" placeholder="Recipient ISCAN email">
        </div>
        <div id="mode-bill" style="display:none;">
          <select id="billerType">
            <option value="">Select Biller</option>
            <option value="meralco">Meralco</option>
            <option value="pldt">PLDT</option>
            <option value="maynilad">Maynilad</option>
            <option value="globe">Globe</option>
            <option value="smart">Smart</option>
            <option value="other">Other</option>
          </select>
          <input id="billAccountNo" placeholder="Account / Reference Number">
          <input id="billAccountName" placeholder="Account Name">
        </div>
        <input id="sendAmount" type="number" placeholder="Amount" min="0.0001" step="0.0001" oninput="updatePreview()">
        <select id="sendCurrency" onchange="updatePreview()">
          <option value="USDC">USDC</option>
          <option value="ETH">ETH</option>
          <option value="RON">RON</option>
          <option value="PHP">PHP (Internal)</option>
        </select>
        <input id="sendNotes" placeholder="Notes (optional)">
        <div class="preview-box" id="previewBox">
          <div class="preview-row"><span>Amount</span><span id="previewAmount">—</span></div>
          <div class="preview-row"><span>Rate</span><span id="previewRate">—</span></div>
          <div class="preview-row"><span>Fee (0.5%)</span><span id="previewFee">—</span></div>
          <div class="preview-total"><span>Recipient gets</span><span id="previewTotal">—</span></div>
        </div>
        <button class="btn btn-green" onclick="sendPayment()">Send</button>
        <div id="sendMsg" class="msg"></div>
      </div>

      <!-- ── SWAP panel ── -->
      <div class="card">
        <h3>🔄 Swap</h3>
        <p style="color:#6b7280;font-size:12px;margin-bottom:10px;">Swap between tokens using your connected wallet balance.</p>
        <label style="font-size:11px;color:#6b7280;display:block;margin-top:8px;">From</label>
        <select id="swapFrom">
          <option value="USDC">USDC</option>
          <option value="ETH">ETH</option>
          <option value="RON">RON</option>
          <option value="PHP">PHP (Internal)</option>
        </select>
        <label style="font-size:11px;color:#6b7280;display:block;margin-top:8px;">To</label>
        <select id="swapTo">
          <option value="PHP">PHP (Internal)</option>
          <option value="USDC">USDC</option>
          <option value="ETH">ETH</option>
          <option value="RON">RON</option>
        </select>
        <input id="swapAmount" type="number" placeholder="Amount" min="0.0001" step="0.0001" oninput="updateSwapPreview()">
        <div class="preview-box" id="swapPreviewBox">
          <div class="preview-row"><span>You send</span><span id="swapPreviewFrom">—</span></div>
          <div class="preview-row"><span>Rate</span><span id="swapPreviewRate">—</span></div>
          <div class="preview-row"><span>Fee (0.3%)</span><span id="swapPreviewFee">—</span></div>
          <div class="preview-total"><span>You receive</span><span id="swapPreviewTotal">—</span></div>
        </div>
        <button class="btn btn-primary" style="margin-top:10px;" onclick="executeSwap()">Swap Now</button>
        <div id="swapMsg" class="msg"></div>
      </div>
    </div>
  </div>

  <!-- RECEIVE — unified wallet -->
  <div id="receive-tab" class="sub-screen">
    <div class="card" style="max-width:680px;margin:auto;">
      <h3 style="margin-bottom:4px;">⚡ ISCAN Unified Wallet</h3>
      <p style="color:#6b7280;font-size:12px;margin-bottom:16px;">One account. Any chain. Select how you want to deposit — all funds settle to the same ISCAN balance.</p>

      <!-- Wallet type selector -->
      <div style="display:flex;gap:8px;margin-bottom:18px;">
        <button class="chain-btn active" id="rwTypeISCAN" onclick="selectReceiveType('iscan',this)" style="flex:1;padding:12px;font-size:13px;">
          ⚡ ISCAN Internal
        </button>
        <button class="chain-btn" id="rwTypeCrypto" onclick="selectReceiveType('crypto',this)" style="flex:1;padding:12px;font-size:13px;">
          🔗 Blockchain Deposit
        </button>
      </div>

      <!-- ISCAN panel -->
      <div id="rwPanelISCAN">
        <div class="iscan-receive-panel">
          <div style="font-size:11px;color:#94a3b8;margin-bottom:6px;">ISCAN Internal Address</div>
          <div class="iscan-receive-addr" id="receiveIscanAddr">Loading...</div>
          <canvas id="iscanQrCanvas" width="180" height="180" style="display:block;margin:12px auto;border-radius:8px;background:white;padding:5px;"></canvas>
          <button class="btn btn-primary" style="margin-top:4px;" onclick="copyIscanReceiveAddr()">📋 Copy ISCAN Address</button>
        </div>
        <div style="margin-top:10px;padding:10px;background:#0b1220;border:1px solid #1f2937;border-radius:8px;display:flex;gap:10px;align-items:center;">
          <span style="font-size:18px;">✅</span>
          <div>
            <div style="font-size:12px;color:#22c55e;font-weight:600;">Zero fees · Instant settlement</div>
            <div style="font-size:11px;color:#6b7280;">For transfers between ISCAN users. PHP balance updates immediately.</div>
          </div>
        </div>
      </div>

      <!-- Crypto panel -->
      <div id="rwPanelCrypto" style="display:none;">
        <!-- Chain selector -->
        <div style="margin-bottom:12px;">
          <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Select Chain</div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;" id="chainSelector">
            <button class="chain-btn active" data-chain="0x1" data-name="Ethereum" onclick="selectReceiveChain(this)">🔷 Ethereum</button>
            <button class="chain-btn" data-chain="0x89" data-name="Polygon" onclick="selectReceiveChain(this)">🟣 Polygon</button>
            <button class="chain-btn" data-chain="0x38" data-name="BNB Chain" onclick="selectReceiveChain(this)">🟡 BNB</button>
            <button class="chain-btn" data-chain="0x7e4" data-name="Ronin" onclick="selectReceiveChain(this)">🔵 Ronin</button>
            <button class="chain-btn" data-chain="0xa4b1" data-name="Arbitrum" onclick="selectReceiveChain(this)">🔵 Arbitrum</button>
            <button class="chain-btn" data-chain="0xa" data-name="Optimism" onclick="selectReceiveChain(this)">🔴 Optimism</button>
            <button class="chain-btn" data-chain="0x2105" data-name="Base" onclick="selectReceiveChain(this)">🔷 Base</button>
          </div>
        </div>

        <!-- Token selector -->
        <div style="margin-bottom:14px;">
          <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Select Token</div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;" id="tokenSelector">
            <button class="chain-btn active" data-token="native" onclick="selectReceiveToken(this)">Native</button>
            <button class="chain-btn" data-token="USDC" onclick="selectReceiveToken(this)">USDC</button>
            <button class="chain-btn" data-token="USDT" onclick="selectReceiveToken(this)">USDT</button>
          </div>
        </div>

        <!-- QR output -->
        <div id="cryptoReceiveOutput" style="display:none;text-align:center;background:linear-gradient(135deg,#0f2744,#111827);border:1px solid #2563eb;border-radius:12px;padding:20px;">
          <div style="font-size:11px;color:#94a3b8;margin-bottom:4px;" id="rwChainLabel">Ethereum · USDC</div>
          <canvas id="qrCanvas" width="200" height="200" style="display:block;margin:10px auto;border-radius:8px;background:white;padding:6px;"></canvas>
          <div style="font-family:monospace;font-size:12px;color:#60a5fa;word-break:break-all;padding:10px;background:#0b1220;border:1px solid #1f2937;border-radius:8px;margin-top:8px;" id="myWalletAddr"></div>
          <button class="btn btn-primary" style="margin-top:10px;" onclick="copyMyAddress()">📋 Copy Address</button>
          <div style="margin-top:10px;font-size:11px;color:#6b7280;">Deposits on this chain auto-settle to your ISCAN balance after confirmation.</div>
        </div>
        <div id="cryptoReceiveNoWallet" style="padding:16px;background:#0b1220;border:1px solid #374151;border-radius:10px;text-align:center;">
          <div style="font-size:22px;margin-bottom:8px;">🔌</div>
          <div style="color:#94a3b8;font-size:13px;margin-bottom:8px;">No wallet linked for this chain</div>
          <button class="btn btn-primary btn-sm" style="width:auto;" onclick="switchTab('wallets',document.querySelector('[onclick*=wallets]'))">Go to Wallets →</button>
        </div>
      </div>
    </div>
  </div>

  <!-- SCAN -->
  <div id="scan-tab" class="sub-screen">
    <div class="card" style="max-width:460px;">
      <h3>📷 Scan QR Code</h3>
      <p style="color:#6b7280;font-size:12px;margin-bottom:10px;">Scan wallet address or payment request</p>
      <button class="btn btn-primary" onclick="startScan()">Start Camera</button>
      <button class="btn btn-amber" style="margin-top:6px;" onclick="stopScan()">Stop</button>
      <video id="scanVideo" autoplay playsinline></video>
      <canvas id="scanCanvas" style="display:none;"></canvas>
      <div id="scanResult"></div>
      <div id="scanMsg" class="msg"></div>
    </div>
  </div>

  <!-- ISCAN INTERNAL TRANSFER -->
  <div id="iscan-tab" class="sub-screen">
    <div class="card" style="max-width:500px;">
      <h3>⚡ ISCAN-to-ISCAN Transfer</h3>
      <p style="color:#6b7280;font-size:12px;margin-bottom:10px;">Transfer PHP instantly between ISCAN users. No blockchain fees.</p>
      <div class="iscan-box" style="margin-bottom:10px;">
        <div style="font-size:11px;color:#94a3b8;">Your ISCAN Address</div>
        <div class="iscan-addr" id="myIscanAddr">—</div>
      </div>
      <input id="iscanReceiverEmail" placeholder="Recipient email or ISCAN address">
      <input id="iscanAmount" type="number" placeholder="Amount (PHP)" min="1">
      <input id="iscanNotes" placeholder="Notes (optional)">
      <button class="btn btn-green" onclick="iscanTransfer()">Transfer Instantly</button>
      <div id="iscanMsg" class="msg"></div>
    </div>
  </div>

  <!-- CASH IN -->
  <div id="cashin-tab" class="sub-screen">
    <div class="card" style="max-width:500px;">
      <h3>💳 Cash In via GCash / Card</h3>
      <p style="color:#6b7280;font-size:12px;margin-bottom:10px;">Deposit PHP to your ISCAN wallet instantly using GCash or debit/credit card.</p>
      <input id="cashinAmount" type="number" placeholder="Amount (PHP) — min ₱20" min="20" max="100000">
      <button class="btn btn-green" style="margin-top:8px;" onclick="startCashIn()">Generate Payment Link</button>
      <div id="cashinMsg" style="margin-top:12px;padding:10px;border-radius:8px;font-size:13px;min-height:20px;"></div>
    </div>
  </div>

  <!-- CRYPTO CASH IN -->
  <div id="crypto-cashin-tab" class="sub-screen">
    <div class="card" style="max-width:500px;">
      <h3>🪙 Crypto Cash In — USDC / USDT → PHP</h3>
      <p style="color:#6b7280;font-size:12px;margin-bottom:14px;">Convert stablecoins to PHP and receive via Maya or GCash instantly.</p>
      <style>
      .crypto-panel{display:flex;flex-direction:column;gap:16px;}
      .token-selector{display:flex;gap:8px;margin-bottom:4px;}
      .token-btn{flex:1;padding:10px;border:1px solid var(--border);border-radius:8px;background:var(--surface2);color:var(--muted);font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .15s;}
      .token-btn.active{border-color:var(--accent);background:rgba(45,232,162,.10);color:var(--accent);}
      .token-icon{width:20px;height:20px;border-radius:50%;font-size:10px;font-weight:800;display:flex;align-items:center;justify-content:center;}
      .usdc-icon{background:#2775ca;color:#fff;}
      .usdt-icon{background:#26a17b;color:#fff;}
      .channel-selector{display:flex;gap:8px;}
      .channel-btn{flex:1;padding:10px 8px;border:1px solid var(--border);border-radius:8px;background:var(--surface2);color:var(--muted);font-size:12px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:4px;transition:all .15s;}
      .channel-btn.active{border-color:var(--accent);background:rgba(45,232,162,.08);color:var(--text);}
      .channel-btn .ch-name{font-weight:600;font-size:12.5px;}
      .channel-btn .ch-fee{font-size:10px;color:var(--muted);}
      .channel-btn.active .ch-fee{color:var(--accent);}
      .rate-box{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px 14px;display:flex;align-items:center;justify-content:space-between;}
      .rate-label{font-size:11px;color:var(--muted);}
      .rate-value{font-size:15px;font-weight:700;color:var(--accent);}
      .rate-refresh{background:none;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:0;transition:transform .3s;}
      .rate-refresh:hover{color:var(--accent);}
      .rate-refresh.spinning{animation:spin .6s linear infinite;}
      @keyframes spin{to{transform:rotate(360deg);}}
      .breakdown{background:var(--surface2);border:1px solid var(--border);border-radius:8px;overflow:hidden;font-size:12.5px;}
      .breakdown-row{display:flex;justify-content:space-between;padding:9px 14px;border-bottom:1px solid var(--border);color:var(--muted);}
      .breakdown-row:last-child{border-bottom:none;}
      .breakdown-row.total{background:rgba(45,232,162,.06);color:var(--text);font-weight:700;}
      .breakdown-row.total .bd-val{color:var(--accent);font-size:14px;}
      .step-label{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:6px;}
      .status-banner{display:none;padding:11px 14px;border-radius:8px;font-size:12.5px;line-height:1.5;white-space:pre-line;}
      .status-banner.pending{background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.25);color:#fbbf24;}
      .status-banner.success{background:rgba(45,232,162,.08);border:1px solid rgba(45,232,162,.25);color:var(--accent);}
      .status-banner.error{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);color:#f87171;}
      .gcash-notice{font-size:11.5px;color:var(--muted);text-align:center;margin-top:-6px;}
      .gcash-notice a{color:var(--accent);text-decoration:none;}
      </style>
      <div class="crypto-panel" id="crypto-onramp-panel">
        <div>
          <div class="step-label">1 — Select Token</div>
          <div class="token-selector">
            <button class="token-btn active" data-token="USDC" onclick="selectToken('USDC', this)">
              <span class="token-icon usdc-icon">U</span> USDC
            </button>
            <button class="token-btn" data-token="USDT" onclick="selectToken('USDT', this)">
              <span class="token-icon usdt-icon">₮</span> USDT
            </button>
          </div>
        </div>
        <div>
          <div class="step-label">2 — Payout Channel</div>
          <div class="channel-selector">
            <button class="channel-btn active" data-channel="maya" onclick="selectChannel('maya', this)">
              <span class="ch-name">Maya</span><span class="ch-fee">1.5% fee</span>
            </button>
            <button class="channel-btn" data-channel="gcash" onclick="selectChannel('gcash', this)">
              <span class="ch-name">GCash</span><span class="ch-fee">2.0% fee</span>
            </button>
          </div>
        </div>
        <div class="rate-box">
          <div>
            <div class="rate-label">Live Rate</div>
            <div class="rate-value" id="or-rate-display">Fetching…</div>
          </div>
          <button class="rate-refresh" id="or-refresh-btn" onclick="refreshRate()" title="Refresh rate">↻</button>
        </div>
        <div>
          <div class="step-label">3 — Enter USD Amount</div>
          <div class="input-wrap">
            <div class="input-prefix">$</div>
            <input id="or-usd-amount" type="number" min="1" max="10000" step="0.01" placeholder="0.00" oninput="updateBreakdown()">
          </div>
        </div>
        <div class="breakdown" id="or-breakdown" style="display:none">
          <div class="breakdown-row"><span>Gross PHP</span><span class="bd-val" id="bd-gross">—</span></div>
          <div class="breakdown-row"><span>Fee (<span id="bd-fee-pct">—</span>)</span><span class="bd-val" id="bd-fee">—</span></div>
          <div class="breakdown-row total"><span>You Receive</span><span class="bd-val" id="bd-net">—</span></div>
        </div>
        <div>
          <div class="step-label">4 — Recipient Mobile Number</div>
          <div class="input-wrap">
            <div class="input-prefix">+63</div>
