// ── TOKEN BALANCES (generic ERC-20 + native) ───────────────
var TOKEN_DECIMALS = { USDC:6, USDT:6, WETH:18, AXS:18, SLP:18, ARB:18 };

async function getTokenBalance(provider, address, chainId, symbol) {
  var contract = (TOKEN_CONTRACTS[chainId]||{})[symbol];
  if (!contract) return 0;
  try {
    var data = '0x70a08231' + '000000000000000000000000' + address.slice(2).padStart(40,'0');
    var result = await provider.request({method:'eth_call', params:[{to:contract,data},'latest']});
    var dec = TOKEN_DECIMALS[symbol] !== undefined ? TOKEN_DECIMALS[symbol] : 18;
    return parseInt(result,16) / Math.pow(10, dec);
  } catch(e) { return 0; }
}

// Legacy alias
async function getUSDCBalance(provider, address, chainId) {
  return getTokenBalance(provider, address, chainId, 'USDC');
}

// Fetch ALL token balances for a wallet on a given chain
async function getAllTokenBalances(provider, address, chainId) {
  var native = 0;
  try {
    var bw = await provider.request({method:'eth_getBalance', params:[address,'latest']});
    native = parseFloat((parseInt(bw,16)/1e18).toFixed(6));
  } catch(e){}
  var nativeSym = (CHAIN_MAP[chainId]||{token:'ETH'}).token;
  var balances = { native, [nativeSym]: native };
  var tokens = (CHAIN_TOKENS[chainId]||[]).filter(t=>t!=='native');
  await Promise.all(tokens.map(async sym => {
    balances[sym] = parseFloat((await getTokenBalance(provider, address, chainId, sym)).toFixed(6));
  }));
  return balances;
}

// ── TOKEN CHIP RENDERER ─────────────────────────────────────
var TOKEN_COLORS = {
  ETH:'#627eea', MATIC:'#8247e5', BNB:'#f3ba2f', RON:'#1273ea',
  USDC:'#2775ca', USDT:'#26a17b', WETH:'#627eea',
  AXS:'#1273ea', SLP:'#00d4ff', ARB:'#28a0f0',
};
function renderTokenChips(w, chainInfo) {
  var chips = [];
  // Always show native balance
  var nativeSym = chainInfo.token;
  var nativeColor = chainInfo.color || TOKEN_COLORS[nativeSym] || '#94a3b8';
  chips.push('<span class="token-chip" style="color:'+nativeColor+'">'+(w.nativeBalance||0)+' '+nativeSym+'</span>');
  // Show any extra token balances stored in tokenBalances map
  var tb = w.tokenBalances || {};
  var knownTokens = (CHAIN_TOKENS[w.chainId]||[]).filter(t=>t!=='native');
  knownTokens.forEach(function(sym) {
    if(sym === nativeSym) return; // already shown
    var val = tb[sym] !== undefined ? tb[sym] : (sym==='USDC' ? (w.usdcBalance||0) : 0);
    if(val > 0) {
      var col = TOKEN_COLORS[sym] || '#94a3b8';
      chips.push('<span class="token-chip" style="color:'+col+'">'+parseFloat(val).toFixed(4)+' '+sym+'</span>');
    }
  });
  return chips.join('');
}

