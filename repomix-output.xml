async function updateReceiveQR(){
  var r=await api('/api/v1/wallet/list');
  _linkedWallets=r.data&&r.data.wallets||[];
  var matched=_linkedWallets.find(w=>w.chainId===_receiveChain);
  var out=document.getElementById('cryptoReceiveOutput');
  var noWallet=document.getElementById('cryptoReceiveNoWallet');
  var chainBtn=document.querySelector('#chainSelector .chain-btn[data-chain="'+_receiveChain+'"]');
  var chainName=chainBtn?chainBtn.dataset.name||chainBtn.textContent.trim():'Unknown';
  var tokenLabel=_receiveToken==='native'?(CHAIN_MAP[_receiveChain]||{token:'Native'}).token:_receiveToken;
  if(!matched){
    if(out)out.style.display='none';
    if(noWallet)noWallet.style.display='block';
    return;
  }
  if(noWallet)noWallet.style.display='none';
  if(out)out.style.display='block';
