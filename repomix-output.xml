}

// ── CONNECT WALLET ──────────────────────────────────────────
async function connectWallet(type){
  // ── Ronin Wallet ──
  if(type==='ronin'){
    var roninProvider=window.ronin&&window.ronin.provider;
    if(!roninProvider){
      showMsg('walletMsg','error','Ronin Wallet not detected. Install from roninchain.com/wallet and refresh.');
      return;
    }
    try{
      showMsg('walletMsg','info','Connecting Ronin — approve in the Ronin Wallet popup...');
      // NOTE: wallet_requestPermissions is NOT supported in Ronin provider v6.7+
      // Use eth_requestAccounts directly — it will show the approval popup on its own
      var accounts = await roninProvider.request({method:'eth_requestAccounts'});
      if(!accounts||!accounts.length){showMsg('walletMsg','error','No accounts returned from Ronin.');return;}
      var address = accounts[0];
      var chainId = '0x7e4'; // Ronin mainnet always
      var chainInfo = CHAIN_MAP[chainId];

      // Fetch all token balances available on Ronin
      var allBals = await getAllTokenBalances(roninProvider, address, chainId);
      var nativeBal = allBals[chainInfo.token] || 0;

      var payload = {
        address, provider:'ronin', chainId,
        nativeBalance: nativeBal,
        nativeToken: 'RON',
        usdcBalance: allBals['USDC'] || 0,
        tokenBalances: allBals  // full map stored for display
      };
      var r = await api('/api/v1/wallet/link',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      if(r.ok||r.data.success){
        var tokenSummary = Object.entries(allBals)
          .filter(([k,v])=>k!=='native'&&v>0)
          .map(([k,v])=>v.toFixed(4)+' '+k).join(' | ') || nativeBal+' RON';
        showMsg('walletMsg','success','✅ Ronin connected: '+address.substring(0,6)+'...'+address.substring(address.length-4)+' | '+tokenSummary);
        _syncIscanAddress(r.data);myAddress=address;loadWallets();loadWalletsForOverview();updateReceiveQR();
      }else showMsg('walletMsg','error',r.data.error||'Failed to link Ronin wallet.');
    }catch(err){
      if(err.code===4001)showMsg('walletMsg','error','Rejected. Please approve in Ronin Wallet.');
      else showMsg('walletMsg','error','Ronin error: '+err.message);
    }
    return;
  }

  // ── MetaMask ──
  // When multiple wallets are installed (Trust, Coinbase, Ronin) they all inject
  // window.ethereum and may fake isMetaMask=true. We must pick the real MetaMask.
  if(!window.ethereum){
    showMsg('walletMsg','error','MetaMask not detected. Install from metamask.io and refresh.');
    return;
  }
  var provider=null;
  // Multi-provider EIP-5749: find the one that is MetaMask only (not Trust, Coinbase, Ronin)
  if(window.ethereum.providers && Array.isArray(window.ethereum.providers)){
    provider = window.ethereum.providers.find(p =>
      p.isMetaMask && !p.isRonin && !p.isTrust && !p.isTrustWallet && !p.isCoinbaseWallet
    ) || null;
  }
  // Single provider fallback
  if(!provider && window.ethereum.isMetaMask && !window.ethereum.isRonin &&
     !window.ethereum.isTrust && !window.ethereum.isTrustWallet && !window.ethereum.isCoinbaseWallet){
    provider = window.ethereum;
  }
  if(!provider){
    showMsg('walletMsg','error','MetaMask not found. If you have Trust Wallet or Coinbase Wallet installed, disable them temporarily or use a separate browser profile for MetaMask.');
    return;
  }

  try{
    showMsg('walletMsg','info','Connecting MetaMask — approve in the extension popup...');
    // Force account picker every time by requesting permissions first
    await provider.request({method:'wallet_requestPermissions',params:[{eth_accounts:{}}]});
    var accounts=await provider.request({method:'eth_requestAccounts'});
    if(!accounts||!accounts.length){showMsg('walletMsg','error','No accounts returned from MetaMask.');return;}
    var address=accounts[0];
    var chainId = await provider.request({method:'eth_chainId'});
    var chainInfo = CHAIN_MAP[chainId] || {name:'Unknown', token:'ETH', color:'#94a3b8'};
    showMsg('walletMsg','info','Detected '+chainInfo.name+' — reading token balances...');

    // Fetch all token balances for the detected chain
    var allBals = await getAllTokenBalances(provider, address, chainId);
    var nativeBal = allBals[chainInfo.token] || 0;

    var payload = {
      address, provider:'metamask', chainId,
      nativeBalance: nativeBal,
      nativeToken: chainInfo.token,
      usdcBalance: allBals['USDC'] || 0,
      tokenBalances: allBals
    };
    var r = await api('/api/v1/wallet/link',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    if(r.ok||r.data.success){
      var tokenSummary = Object.entries(allBals)
        .filter(([k,v])=>k!=='native'&&v>0)
        .map(([k,v])=>v.toFixed(4)+' '+k).join(' | ') || nativeBal+' '+chainInfo.token;
      showMsg('walletMsg','success','✅ '+chainInfo.name+' connected: '+address.substring(0,6)+'...'+address.substring(address.length-4)+' | '+tokenSummary);
      _syncIscanAddress(r.data);myAddress=address;loadWallets();loadWalletsForOverview();updateReceiveQR();
    }else showMsg('walletMsg','error',r.data.error||'Failed to link wallet.');
  }catch(err){
    if(err.code===4001)showMsg('walletMsg','error','Rejected. Please approve in MetaMask.');
    else showMsg('walletMsg','error','MetaMask error: '+err.message);
  }
}

function _syncIscanAddress(data){
