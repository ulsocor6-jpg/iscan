<file path="public/reset-password.html">
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>iSCAN — Reset Password</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#080c12;--surface:#0e1520;--surface2:#141d2e;--border:#1e2d45;
    --accent:#00d4ff;--accent2:#0094ff;--danger:#ff4d6a;--text:#e8f0fe;--muted:#5a7a9a;}
  *{margin:0;padding:0;box-sizing:border-box;}
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);
    min-height:100vh;display:flex;align-items:center;justify-content:center;}
  .bg-grid{position:fixed;inset:0;
    background-image:linear-gradient(rgba(0,212,255,0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,212,255,0.03) 1px,transparent 1px);background-size:40px 40px;}
  .container{position:relative;z-index:1;width:100%;max-width:420px;padding:20px;animation:fadeUp .6s ease;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
  .logo{font-family:'Syne',sans-serif;font-weight:800;font-size:2.4rem;text-align:center;
    background:linear-gradient(135deg,var(--accent),var(--accent2));
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:36px;}
  .card{background:var(--surface);border:1px solid var(--border);border-radius:20px;
    padding:36px;box-shadow:0 0 60px rgba(0,212,255,0.06),0 24px 60px rgba(0,0,0,0.5);}
  .title{font-family:'Syne';font-weight:700;font-size:1.4rem;margin-bottom:24px;}
  .field{margin-bottom:18px;}
  label{display:block;font-size:0.78rem;color:var(--muted);margin-bottom:8px;
    text-transform:uppercase;letter-spacing:.08em;}
  input{width:100%;padding:13px 16px;border-radius:10px;border:1px solid var(--border);
    background:var(--surface2);color:var(--text);outline:none;font-size:1rem;}
  input:focus{border-color:var(--accent);}
  .btn{width:100%;padding:14px;margin-top:10px;border:none;border-radius:10px;
    font-family:'Syne';font-weight:700;font-size:1rem;cursor:pointer;
    background:linear-gradient(135deg,var(--accent),var(--accent2));color:#061018;}
  .btn:disabled{opacity:.6;cursor:not-allowed;}
  .alert{padding:12px;border-radius:8px;font-size:0.85rem;display:none;margin-bottom:16px;}
  .alert-error{background:rgba(255,77,106,0.1);border:1px solid rgba(255,77,106,0.3);color:var(--danger);}
  .alert-success{background:rgba(0,212,255,0.1);border:1px solid rgba(0,212,255,0.3);color:var(--accent);}
  .footer{text-align:center;margin-top:18px;font-size:0.85rem;color:var(--muted);}
  .footer a{color:var(--accent);text-decoration:none;}
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="container">
  <div class="logo">iSCAN.</div>
  <div class="card">
    <div class="title">Set New Password</div>
    <div id="alert-error" class="alert alert-error"></div>
    <div id="alert-success" class="alert alert-success"></div>
    <div class="field">
      <label>New Password</label>
      <input id="password" type="password" placeholder="Min 6 characters" />
    </div>
    <div class="field">
      <label>Confirm Password</label>
      <input id="confirm" type="password" placeholder="Repeat password" />
    </div>
    <button class="btn" id="btn" onclick="doReset()">Reset Password</button>
    <div class="footer"><a href="/login">Back to Login</a></div>
  </div>
</div>
<script>
function showAlert(id, msg) {
  document.getElementById(id).textContent = msg;
  document.getElementById(id).style.display = 'block';
  const other = id === 'alert-error' ? 'alert-success' : 'alert-error';
  document.getElementById(other).style.display = 'none';
}

const token = new URLSearchParams(window.location.search).get('token');

if (!token) {
  showAlert('alert-error', 'Invalid reset link. Please request a new one.');
}

async function doReset() {
  const btn = document.getElementById('btn');
  const password = document.getElementById('password').value;
  const confirm = document.getElementById('confirm').value;

  if (!password || !confirm) { showAlert('alert-error', 'Fill in both fields.'); return; }
  if (password.length < 6) { showAlert('alert-error', 'Password must be at least 6 characters.'); return; }
  if (password !== confirm) { showAlert('alert-error', 'Passwords do not match.'); return; }

  btn.disabled = true;
  btn.textContent = 'Resetting...';

  try {
    const res = await fetch('/api/v1/auth/reset-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token, password })
    });
    const data = await res.json();
    if (!res.ok) { showAlert('alert-error', data.message || 'Reset failed.'); return; }
    showAlert('alert-success', 'Password reset! Redirecting to login...');
    setTimeout(() => { window.location.href = '/login'; }, 1500);
  } catch (err) {
    showAlert('alert-error', 'Server error. Try again.');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Reset Password';
  }
}

document.addEventListener('keydown', e => { if (e.key === 'Enter') doReset(); });
</script>
</body>
</html>
</file>

