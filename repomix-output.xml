<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>

// ── CHAIN MAP ──────────────────────────────────────────────
var CHAIN_MAP = {
  '0x1':    { name:'Ethereum',       token:'ETH',   color:'#627eea' },
  '0x89':   { name:'Polygon',        token:'MATIC',  color:'#8247e5' },
  '0x38':   { name:'BNB Chain',      token:'BNB',   color:'#f3ba2f' },
  '0x7e4':  { name:'Ronin',          token:'RON',   color:'#1273ea' },
  '0x7e5':  { name:'Ronin Testnet',  token:'RON',   color:'#1273ea' },
  '0xa4b1': { name:'Arbitrum',       token:'ETH',   color:'#28a0f0' },
  '0xa':    { name:'Optimism',       token:'ETH',   color:'#ff0420' },
};

var USDC_CONTRACTS = {
  '0x1':  '0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48',
  '0x89': '0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174',
};

// ── HELPERS ────────────────────────────────────────────────
function getCookie(n){var m=document.cookie.match(new RegExp('(^| )'+n+'=([^;]+)'));return m?decodeURIComponent(m[2]):null;}
function showMsg(id,type,text){var el=document.getElementById(id);if(!el)return;el.textContent=text;el.className='msg '+type;}
async function api(url,opts){
  var res=await fetch(url,Object.assign({credentials:'same-origin'},opts||{}));
  var data=await res.json();
  return{ok:res.ok,data:data};
}

// ── AUTH ───────────────────────────────────────────────────
var userEmail=getCookie('iscan_email'),userName=getCookie('iscan_name');
if(!userEmail)window.location.href='/login.html';
document.getElementById('userInfo').textContent=userName||userEmail;

// ── NAV ────────────────────────────────────────────────────
function switchTab(id,btn){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-left button').forEach(b=>b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(btn)btn.classList.add('active');
  var actions={
    ledger:loadLedger,
    settlement:loadPending,
    audit:loadAudit,
    accounts:()=>{loadProfile();loadBanks();},
    wallets:loadWallets,
    overview:()=>{loadBalance();loadRecentLedger();loadWalletsForOverview();},
    pay:()=>{loadMyWalletForQR();loadIscanAddressAll();}
  };
  if(actions[id])actions[id]();
}

function switchSub(id,btn){
  document.querySelectorAll('.sub-screen').forEach(s=>s.classList.remove('active'));
  btn.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
  if(id==='receive-tab'){
    loadMyWalletForQR();loadIscanAddressAll();
    // Default to ISCAN panel
    document.getElementById('rwPanelISCAN').style.display='block';
    document.getElementById('rwPanelCrypto').style.display='none';
    document.getElementById('rwTypeISCAN').classList.add('active');
    document.getElementById('rwTypeCrypto').classList.remove('active');
  }
  if(id==='iscan-tab')loadIscanAddressAll();
}

function switchMode(mode,btn){
  ['crypto','email','bill'].forEach(m=>document.getElementById('mode-'+m).style.display='none');
  document.getElementById('mode-'+mode).style.display='block';
  btn.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

async function handleLogout(){
  try{await fetch('/api/v1/auth/logout',{method:'POST',credentials:'same-origin'});}catch(e){}
  window.location.href='/login.html';
}

// ── LIVE RATES ──────────────────────────────────────────────
var liveRates={USDC:null,ETH:null,RON:null};
async function loadRates(){
  var r=await api('/api/v1/remittance/rates');
  if(r.ok&&r.data.rates){
    liveRates=r.data.rates;
    document.getElementById('rateUSDC').textContent='₱'+Number(r.data.rates.USDC||0).toLocaleString();
    document.getElementById('rateETH').textContent='₱'+Number(r.data.rates.ETH||0).toLocaleString();
    document.getElementById('rateRON').textContent=r.data.rates.RON?'₱'+Number(r.data.rates.RON).toLocaleString():'Fetching...';
    document.getElementById('rateTime').textContent='Updated '+new Date().toLocaleTimeString();
  }
}

// ── ISCAN BALANCE ───────────────────────────────────────────
async function loadBalance(){
  var r=await api('/api/v1/ledger/history');
  if(r.ok){
    var b=r.data.balance||0;
    var fmt='₱'+Number(b).toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
    document.getElementById('iscanBalance').textContent=fmt;
    document.getElementById('ledgerBalance').textContent=fmt;
  }
}

// ── LOAD ISCAN ADDRESS (all display points) ─────────────────
var myIscanAddress='';
async function loadIscanAddressAll(){
  var r=await api('/api/v1/wallet/list');
  if(!r.ok)return;
  var addr=r.data.iscanAddress||'';
  if(!addr)return;
  myIscanAddress=addr;
  // wallets tab
  var wEl=document.getElementById('iscanAddrWallet');
  if(wEl)wEl.textContent=addr;
  // overview card
  var oEl=document.getElementById('iscanAddrDisplay');
  if(oEl)oEl.textContent=addr;
  // iscan transfer tab
  var iEl=document.getElementById('myIscanAddr');
  if(iEl)iEl.textContent=addr;
  // receive tab
  var rEl=document.getElementById('receiveIscanAddr');
  if(rEl)rEl.textContent=addr;
  // draw QR on receive tab
  renderIscanQR(addr);
}

var iscanQrInstance=null;
function renderIscanQR(text){
  var canvas=document.getElementById('iscanQrCanvas');
  if(!canvas||!text)return;
  try{
    if(iscanQrInstance){iscanQrInstance.clear();iscanQrInstance.makeCode(text);}
    else iscanQrInstance=new QRCode(canvas,{text,width:160,height:160,colorDark:'#000000',colorLight:'#ffffff'});
  }catch(e){}
}

function copyIscanAddr(){
  var addr=document.getElementById('iscanAddrWallet').textContent;
  if(!addr||addr==='Loading...'||addr==='—'){alert('ISCAN address not loaded yet.');return;}
  navigator.clipboard.writeText(addr).then(()=>alert('ISCAN address copied!')).catch(()=>{});
}

function copyIscanReceiveAddr(){
  var addr=document.getElementById('receiveIscanAddr').textContent;
  if(!addr||addr==='Loading...'||addr==='—'){alert('ISCAN address not loaded yet.');return;}
  navigator.clipboard.writeText(addr).then(()=>{
    var btn=event.target;btn.textContent='✅ Copied!';
    setTimeout(()=>btn.textContent='📋 Copy ISCAN Address',2000);
  }).catch(()=>{});
}

// ── WALLET OVERVIEW ─────────────────────────────────────────
async function loadWalletsForOverview(){
  var r=await api('/api/v1/wallet/list');
  if(!r.ok)return;
  var wallets=r.data.wallets||[];
  var iscanAddr=r.data.iscanAddress||'—';
  var oEl=document.getElementById('iscanAddrDisplay');
  if(oEl)oEl.textContent=iscanAddr;
  var el=document.getElementById('walletOverview');
  if(wallets.length===0){
    el.innerHTML='<div style="color:#6b7280;font-size:12px;">No wallet connected — go to <strong style="color:#60a5fa;cursor:pointer;" onclick="switchTab(\'wallets\',null)">Wallets tab</strong></div>';
    return;
  }
  var w=wallets[0];
  var chainInfo=CHAIN_MAP[w.chainId]||{name:'Unknown',token:'?',color:'#94a3b8'};
  el.innerHTML=
    '<div class="token-row"><div class="token-label"><span class="token-dot" style="background:'+chainInfo.color+'"></span>'+chainInfo.token+'</div><span class="token-val">'+(w.nativeBalance||0)+' '+chainInfo.token+'</span></div>'+
