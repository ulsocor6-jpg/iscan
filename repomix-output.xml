// ── USDC BALANCE ────────────────────────────────────────────
async function getUSDCBalance(provider,address,chainId){
  var contract=USDC_CONTRACTS[chainId];
  if(!contract)return 0;
  try{
    var data='0x70a08231000000000000000000000000'+address.slice(2).padStart(64,'0');
    var result=await provider.request({method:'eth_call',params:[{to:contract,data},'latest']});
    return parseInt(result,16)/1e6;
  }catch(e){return 0;}
}

// ── CONNECT WALLET ──────────────────────────────────────────
async function connectWallet(type){
  // ── Ronin Wallet ──
  if(type==='ronin'){
    var roninProvider=window.ronin&&window.ronin.provider;
    if(!roninProvider){
      showMsg('walletMsg','error','Ronin Wallet not detected. Install from roninchain.com/wallet and refresh.');
      return;
    }
    try{
      showMsg('walletMsg','info','Connecting Ronin — approve in the Ronin Wallet popup...');
      // Force permission prompt
      await roninProvider.request({method:'wallet_requestPermissions',params:[{eth_accounts:{}}]});
      var accounts=await roninProvider.request({method:'eth_requestAccounts'});
      if(!accounts||!accounts.length){showMsg('walletMsg','error','No accounts returned.');return;}
      var address=accounts[0];
      var chainId='0x7e4'; // Ronin mainnet
      var chainInfo=CHAIN_MAP[chainId];
      var nativeBal=0;
      try{var bw=await roninProvider.request({method:'eth_getBalance',params:[address,'latest']});nativeBal=(parseInt(bw,16)/1e18).toFixed(4);}catch(e){}
      var r=await api('/api/v1/wallet/link',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address,provider:'ronin',chainId,nativeBalance:parseFloat(nativeBal),nativeToken:'RON',usdcBalance:0})});
      if(r.ok||r.data.success){
        showMsg('walletMsg','success','✅ Ronin connected: '+address.substring(0,6)+'...'+address.substring(address.length-4)+' | '+nativeBal+' RON');
        _syncIscanAddress(r.data);myAddress=address;loadWallets();loadWalletsForOverview();updateReceiveQR();
      }else showMsg('walletMsg','error',r.data.error||'Failed to link Ronin wallet.');
    }catch(err){
      if(err.code===4001)showMsg('walletMsg','error','Rejected. Please approve in Ronin Wallet.');
      else showMsg('walletMsg','error','Ronin error: '+err.message);
    }
    return;
  }

  // ── MetaMask ──
  if(!window.ethereum){
    showMsg('walletMsg','error','MetaMask not detected. Install from metamask.io and refresh.');
    return;
  }
  // Prefer MetaMask specifically if multiple providers injected
  var provider=null;
  if(window.ethereum.providers){provider=window.ethereum.providers.find(p=>p.isMetaMask&&!p.isRonin)||null;}
  if(!provider&&window.ethereum.isMetaMask&&!window.ethereum.isRonin)provider=window.ethereum;
  if(!provider){showMsg('walletMsg','error','MetaMask not found. Make sure it is installed and enabled.');return;}

  try{
    showMsg('walletMsg','info','Connecting MetaMask — approve in the extension popup...');
    // Force account picker every time by requesting permissions first
    await provider.request({method:'wallet_requestPermissions',params:[{eth_accounts:{}}]});
    var accounts=await provider.request({method:'eth_requestAccounts'});
    if(!accounts||!accounts.length){showMsg('walletMsg','error','No accounts returned from MetaMask.');return;}
    var address=accounts[0];
    var chainId=await provider.request({method:'eth_chainId'});
    var chainInfo=CHAIN_MAP[chainId]||{name:'Unknown',token:'ETH',color:'#94a3b8'};
    var nativeBal=0;
    try{var bw=await provider.request({method:'eth_getBalance',params:[address,'latest']});nativeBal=(parseInt(bw,16)/1e18).toFixed(4);}catch(e){}
    var usdcBal=await getUSDCBalance(provider,address,chainId);
    var r=await api('/api/v1/wallet/link',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address,provider:'metamask',chainId,nativeBalance:parseFloat(nativeBal),nativeToken:chainInfo.token,usdcBalance:usdcBal})});
    if(r.ok||r.data.success){
      showMsg('walletMsg','success','✅ '+chainInfo.name+' connected: '+address.substring(0,6)+'...'+address.substring(address.length-4)+' | '+nativeBal+' '+chainInfo.token+(usdcBal>0?' | '+usdcBal.toFixed(2)+' USDC':''));
      _syncIscanAddress(r.data);myAddress=address;loadWallets();loadWalletsForOverview();updateReceiveQR();
    }else showMsg('walletMsg','error',r.data.error||'Failed to link wallet.');
  }catch(err){
    if(err.code===4001)showMsg('walletMsg','error','Rejected. Please approve in MetaMask.');
    else showMsg('walletMsg','error','MetaMask error: '+err.message);
  }
}

function _syncIscanAddress(data){
  if(!data||!data.iscanAddress)return;
  myIscanAddress=data.iscanAddress;
  ['iscanAddrWallet','iscanAddrDisplay','myIscanAddr','receiveIscanAddr'].forEach(function(id){var el=document.getElementById(id);if(el)el.textContent=myIscanAddress;});
  renderIscanQR(myIscanAddress);
}

