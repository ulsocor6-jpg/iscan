nav button{background:transparent;border:1px solid #1f2937;color:#94a3b8;padding:7px 12px;border-radius:8px;cursor:pointer;font-size:12px;transition:all 0.2s;}
nav button.active{background:#2563eb;border-color:#2563eb;color:white;}
