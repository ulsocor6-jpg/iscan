// ── SEND PAYMENT ──────────────────────────────────────────────
async function sendPayment(){
  var amount=parseFloat(document.getElementById('sendAmount').value);
  var currency=document.getElementById('sendCurrency').value;
  var notes=document.getElementById('sendNotes').value.trim();
  if(!amount||amount<=0){showMsg('sendMsg','error','Enter a valid amount.');return;}
  var activeMode='crypto';
  ['crypto','email','bill'].forEach(m=>{if(document.getElementById('mode-'+m).style.display!=='none')activeMode=m;});
  if(activeMode==='email'){
    var email=document.getElementById('receiverEmail').value.trim();
    if(!email){showMsg('sendMsg','error','Enter recipient email.');return;}
    var r2=await api('/api/v1/transfer/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({receiverEmail:email,amount})});
    if(r2.ok){showMsg('sendMsg','success','Sent! Ref: '+r2.data.referenceId);loadBalance();}
    else showMsg('sendMsg','error',r2.data.error||'Transfer failed.');
    return;
  }
  var body={amount,currency,notes};
  if(activeMode==='crypto'){
    body.senderAddress=document.getElementById('senderAddr').value.trim();
    body.receiverAddress=document.getElementById('receiverAddr').value.trim();
    if(!body.senderAddress||!body.receiverAddress){showMsg('sendMsg','error','Fill in both wallet addresses.');return;}
  }else{
    var biller=document.getElementById('billerType').value;
    var accNo=document.getElementById('billAccountNo').value.trim();
    if(!biller||!accNo){showMsg('sendMsg','error','Select biller and enter account number.');return;}
    body.senderAddress='ISCAN-BILLS';
    body.receiverAddress='BILLS-'+biller.toUpperCase();
    body.notes='Bill payment: '+biller+' — '+accNo;
  }
  var r=await api('/api/v1/remittance/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  if(r.ok){
    var tx=r.data.transaction;
    showMsg('sendMsg','success','Sent! Ref: '+tx.referenceId+(tx.phpEquivalent?' | Recipient gets ₱'+Number(tx.phpEquivalent).toLocaleString():''));
    document.getElementById('previewBox').style.display='none';
    document.getElementById('sendAmount').value='';
  }else showMsg('sendMsg','error',r.data.message||'Send failed.');
}

